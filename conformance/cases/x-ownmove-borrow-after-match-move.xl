enum Sign { Neg(); Zero(); Pos(); }

fn main () -> own unit pure {
  doc "OWN-1/OWN-13: matching an own value moves it; borrowing the now-dead binding afterward is a use-after-move.";
  let s: own Sign = Pos();
  match s {
    Neg() => { }
    Zero() => { }
    Pos() => { }
  }
  region 'r {
    let b: &'r Sign = &'r s;
  }
  return unit;
}
