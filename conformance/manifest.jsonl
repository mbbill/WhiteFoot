# xlang conformance manifest — one JSON object per case (blank / #-lines ignored).
# id -> cases/<id>.xl ; rules[] -> spec rule ids exercised ; expect -> required verdict.
# status: runnable (must match) | pending (toolchain can't run yet) | xfail (tracked gap).
{"id": "run-ex1-value-match", "rules": ["GRAM-10", "GRAM-11", "GIVE-1", "ERR-1", "OP-1"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "EX-1-class program: let-init give value-match, named binders, named user-fn call, checked arithmetic; runs to exit 0."}
{"id": "run-ex2-loop-trap-folds", "rules": ["GRAM-4", "OP-1", "OP-2"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "loop + trapping arithmetic; every trap proven away at -O2, folds to a constant return."}
{"id": "reject-err2-nonexhaustive", "rules": ["ERR-2"], "expect": {"kind": "reject", "rule": "ERR-2"}, "status": "runnable", "doc": "A match missing a variant arm is rejected; exhaustiveness cannot be silenced (W3)."}
{"id": "reject-own10-dangle", "rules": ["OWN-10"], "expect": {"kind": "reject", "rule": "OWN-10"}, "status": "runnable", "doc": "Returning a borrow of an own parameter into a caller region is a dangling reference; rejected before codegen."}
{"id": "trap-op5-check-fails", "rules": ["OP-5", "SCOPE-4"], "expect": {"kind": "trap"}, "status": "runnable", "doc": "A failed check traps at runtime and aborts (no unwinding)."}
{"id": "reject-gram11-unnamed-call", "rules": ["GRAM-11"], "expect": {"kind": "reject", "rule": "GRAM-11"}, "status": "pending", "reason": "democ rejects positional user-calls at parse time via a bare assertion, without citing GRAM-11 (a DIAG-1 gap in the demo parser); runnable once parse errors cite rule ids", "doc": "A user-fn call with positional (unnamed) args must be rejected citing GRAM-11; named-in-declared-order is required."}
{"id": "xfail-own1-bare-affine-use", "rules": ["OWN-1"], "expect": {"kind": "reject", "rule": "OWN-1"}, "status": "xfail", "reason": "type layer does not yet enforce copy/affine bare-use; found 2026-07-08, fix with the memory cluster", "doc": "A bare use of an affine value must be rejected (write move); currently accepted."}
{"id": "pending-op9-buffer-new", "rules": ["TYPE-2", "OP-9"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no buffer codegen yet", "doc": "buffer_new allocates a runtime-length flat buffer; size-overflow traps [OP-9]."}
{"id": "pending-const2-item", "rules": ["CONST-2"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no const-item support yet", "doc": "A named immutable const item."}
