  let writes_output: own u64 = semantic_body_child_at(ast: ast, node: writes_node, ordinal: 0_u64);
  let writes_output_valid: own Bool = semantic_reader_reborrow_span_region_matches(source: source, tokens: tokens, ast: ast, node: writes_output, expected_head: output_region_head);
  match writes_output_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let ast_traps_effect_atom: own AstKind = AstTrapsEffect();
  let traps_kind: own Bool = semantic_body_kind_is(ast: ast, node: traps_node, want: ast_traps_effect_atom);
  let traps_leaf: own Bool = semantic_reader_writer_leaf_token_exact(source: source, tokens: tokens, ast: ast, node: traps_node);
  let traps_word: own Bool = semantic_function_effect_word_valid(source: source, tokens: tokens, ast: ast, node: traps_node, code: 3_u64);
  let ast_block_atom: own AstKind = AstBlock();
  let body_kind: own Bool = semantic_body_kind_is(ast: ast, node: body, want: ast_block_atom);
  let body_token: own Bool = semantic_buffer_single_symbol_node(source: source, tokens: tokens, ast: ast, node: body, want: 123_u8);
  let traps_first: own Bool = band<Bool>(traps_kind, traps_leaf);
  let traps_valid: own Bool = band<Bool>(traps_first, traps_word);
  let body_valid: own Bool = band<Bool>(body_kind, body_token);
  return band<Bool>(traps_valid, body_valid);
}
