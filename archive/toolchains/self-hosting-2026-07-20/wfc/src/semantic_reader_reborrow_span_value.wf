fn semantic_reader_reborrow_span_index_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64, source_head: own u64, cursor_head: own u64) -> own Bool reads('c), traps {
