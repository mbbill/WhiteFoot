+def _periodic_contract_expr(expr, local_exprs, roles):
+    """Alpha-normalize and expand the pure precondition expression DAG."""
+    kind = expr.get("e")
+    if kind == "lit":
+        return ("lit", expr.get("ty"), expr.get("v"))
+    if kind == "place":
+        place = expr.get("p", {})
+        if place.get("path") != [] or "index" in place or "post" in place:
+            return None
+        name = place.get("base")
+        if place.get("deref") == 0:
+            if name in local_exprs: return local_exprs[name]
+            if name in roles: return ("role", roles[name])
+            return None
+        if place.get("deref") == 1 and roles.get(name) == "buffer":
+            return ("deref", ("role", "buffer"))
+        return None
+    if kind == "op":
+        args = tuple(_periodic_contract_expr(a, local_exprs, roles)
+                     for a in expr.get("args", []))
+        if any(a is None for a in args): return None
+        return ("op", expr.get("op"), tuple(expr.get("tyargs", [])), args)
+    return None
