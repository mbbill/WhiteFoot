+def _certify_periodic_copy(function):
+    plan = _periodic_body_plan(function)
+    requires = function.get("requires") or []
+    if plan is None or len(requires) != 28: return None
+    roles = {name: role for role, name in plan.items()}
+    locals_seen = {}
+    for stmt in requires[:-1]:
+        if (stmt.get("s") != "let" or stmt.get("m", {}).get("kind") != "own"
+                or stmt.get("n") in locals_seen):
+            return None
+        value = _periodic_contract_expr(stmt.get("e", {}), locals_seen, roles)
+        if value is None: return None
+        locals_seen[stmt["n"]] = value
+    check = requires[-1]
+    if check.get("s") != "check": return None
+    observed = _periodic_contract_expr(check.get("e", {}), locals_seen, roles)
+    return plan if observed == _PERIODIC_EXPECTED_CONTRACT else None
