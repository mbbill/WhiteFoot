fn inflate_huffman_literals ['s, 'o] (src: &'s buffer<u8>, out: &uniq 'o buffer<u8>, symbol_count: own u64) -> own u64 reads('s), writes('o), traps requires {
  let required_src_len: own u64 = len<u8>(deref(src));
  let required_out_len: own u64 = len<u8>(deref(out));
  let required_full_eighths: own u64 = ishr.wrap<u64>(symbol_count, 3_u32);
  let required_remainder: own u64 = iand<u64>(symbol_count, 7_u64);
  let required_base_bytes: own u64 = iadd.wrap<u64>(symbol_count, required_full_eighths);
  let count_bounded: own Bool = ile<u64>(symbol_count, 16397105843297379213_u64);
  let remainder_zero: own Bool = ieq<u64>(required_remainder, 0_u64);
  let remainder_nonzero: own Bool = ine<u64>(required_remainder, 0_u64);
  let input_exact: own Bool = ige<u64>(required_src_len, required_base_bytes);
  let input_with_tail: own Bool = igt<u64>(required_src_len, required_base_bytes);
  let zero_case: own Bool = band<Bool>(remainder_zero, input_exact);
  let tail_case: own Bool = band<Bool>(remainder_nonzero, input_with_tail);
  let input_valid: own Bool = bor<Bool>(zero_case, tail_case);
  let output_valid: own Bool = ige<u64>(required_out_len, symbol_count);
  let buffers_valid: own Bool = band<Bool>(input_valid, output_valid);
  let all_valid: own Bool = band<Bool>(count_bounded, buffers_valid);
  check all_valid else trap "invalid Huffman buffers";
} {
  doc "Decode prepared DEFLATE literal table entries with the canonical byte-fed bit accumulator and table lookup shape.";
  let input_pos: own u64 = 0_u64;
  let output_pos: own u64 = 0_u64;
  let hold: own u64 = 0_u64;
  let bits: own u32 = 0_u32;
  loop @symbols {
    match ige<u64>(output_pos, symbol_count) {
      True() => {
        break @symbols;
      }
      False() => {
      }
    }
    loop @refill {
      match ige<u32>(bits, 9_u32) {
        True() => {
          break @refill;
        }
        False() => {
        }
      }
      let byte: own u8 = index<u8>(deref(src), input_pos);
      let wide: own u64 = cvt<u8, u64>(byte);
      let shifted: own u64 = ishl.wrap<u64>(wide, bits);
      set hold = ior<u64>(hold, shifted);
      set bits = iadd.wrap<u32>(bits, 8_u32);
      set input_pos = iadd.wrap<u64>(input_pos, 1_u64);
    }
    let table_index: own u64 = iand<u64>(hold, 511_u64);
    let entry: own u32 = index<u32>(fixed_lencode, table_index);
    let operation: own u32 = iand<u32>(entry, 255_u32);
    let shifted_bits: own u32 = ishr.wrap<u32>(entry, 8_u32);
    let used: own u32 = iand<u32>(shifted_bits, 255_u32);
    let symbol_word: own u32 = ishr.wrap<u32>(entry, 16_u32);
    match ieq<u32>(operation, 0_u32) {
      True() => {
      }
      False() => {
        check ieq<u64>(0_u64, 1_u64) else trap "non-literal fixed code";
      }
    }
    match cvt<u32, u8>(symbol_word) {
      Ok(value: symbol) => {
        set index<u8>(deref(out), output_pos) = symbol;
      }
      Err(error: error) => {
        check ieq<u64>(0_u64, 1_u64) else trap "invalid literal table entry";
      }
    }
    set hold = ishr.wrap<u64>(hold, used);
    set bits = isub.wrap<u32>(bits, used);
    set output_pos = iadd.wrap<u64>(output_pos, 1_u64);
  }
  return output_pos;
}
