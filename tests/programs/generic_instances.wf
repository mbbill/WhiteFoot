fn maximum<T: Int>(left: own T, right: own T) -> own T pure {
  return imax<T>(left, right);
}

fn preserve<const n: u64>(value: own array<u8, n>) -> own array<u8, n> pure {
  let size: own u64 = len<u8>(value);
  return move value;
}

fn forward<const n: u64>(value: own array<u8, n>) -> own array<u8, n> pure {
  return preserve<n>(value: move value);
}

fn filled_array<T: Int, const n: u64>(value: own T) -> own array<T, n> pure {
  return array_new<T, n>(value);
}

fn filled_buffer<T: Int>(length: own u64, value: own T) -> own buffer<T> allocates(heap), traps {
  return buffer_new<T>(length, value);
}

fn main() -> own unit allocates(heap), traps {
  let small_maximum: own u8 = maximum<u8>(left: 4_u8, right: 9_u8);
  let signed_maximum: own i64 = maximum<i64>(left: -7_i64, right: -2_i64);
  let short_input: own array<u8, 2> = array_new<u8, 2>(7_u8);
  let short: own array<u8, 2> = forward<2>(value: move short_input);
  let long_input: own array<u8, 5> = array_new<u8, 5>(11_u8);
  let long: own array<u8, 5> = forward<5>(value: move long_input);
  let short_value: own u8 = index<u8>(short, 1_u64);
  let long_value: own u8 = index<u8>(long, 4_u64);
  let typed_bytes: own array<u8, 2> = filled_array<u8, 2>(value: 13_u8);
  let typed_words: own array<i64, 3> = filled_array<i64, 3>(value: -17_i64);
  let typed_byte: own u8 = index<u8>(typed_bytes, 1_u64);
  let typed_word: own i64 = index<i64>(typed_words, 2_u64);
  let storage: own buffer<u16> = filled_buffer<u16>(length: 2_u64, value: 19_u16);
  let stored: own u16 = index<u16>(storage, 1_u64);
  check ieq<u8>(small_maximum, 9_u8) else trap "u8 generic maximum";
  check ieq<i64>(signed_maximum, -2_i64) else trap "i64 generic maximum";
  check ieq<u8>(short_value, 7_u8) else trap "short const instance";
  check ieq<u8>(long_value, 11_u8) else trap "long const instance";
  check ieq<u8>(typed_byte, 13_u8) else trap "typed byte array";
  check ieq<i64>(typed_word, -17_i64) else trap "typed word array";
  check ieq<u16>(stored, 19_u16) else trap "typed buffer";
  return unit;
}
