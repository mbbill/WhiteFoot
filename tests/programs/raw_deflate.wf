enum InflateError {
  Truncated();
  InvalidStoredLength();
  InvalidHuffmanCode();
  InvalidDistance();
  OutputFull();
  UnsupportedBlockType();
}

struct InflateState {
  input_offset: u64;
  output_offset: u64;
  hold: u64;
  bits: u32;
}

const length_bases: array<u16, 29> = [3_u16, 4_u16, 5_u16, 6_u16, 7_u16, 8_u16, 9_u16, 10_u16, 11_u16, 13_u16, 15_u16, 17_u16, 19_u16, 23_u16, 27_u16, 31_u16, 35_u16, 43_u16, 51_u16, 59_u16, 67_u16, 83_u16, 99_u16, 115_u16, 131_u16, 163_u16, 195_u16, 227_u16, 258_u16];

const length_extras: array<u8, 29> = [0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 1_u8, 1_u8, 1_u8, 1_u8, 2_u8, 2_u8, 2_u8, 2_u8, 3_u8, 3_u8, 3_u8, 3_u8, 4_u8, 4_u8, 4_u8, 4_u8, 5_u8, 5_u8, 5_u8, 5_u8, 0_u8];

const distance_bases: array<u16, 30> = [1_u16, 2_u16, 3_u16, 4_u16, 5_u16, 7_u16, 9_u16, 13_u16, 17_u16, 25_u16, 33_u16, 49_u16, 65_u16, 97_u16, 129_u16, 193_u16, 257_u16, 385_u16, 513_u16, 769_u16, 1025_u16, 1537_u16, 2049_u16, 3073_u16, 4097_u16, 6145_u16, 8193_u16, 12289_u16, 16385_u16, 24577_u16];

const distance_extras: array<u8, 30> = [0_u8, 0_u8, 0_u8, 0_u8, 1_u8, 1_u8, 2_u8, 2_u8, 3_u8, 3_u8, 4_u8, 4_u8, 5_u8, 5_u8, 6_u8, 6_u8, 7_u8, 7_u8, 8_u8, 8_u8, 9_u8, 9_u8, 10_u8, 10_u8, 11_u8, 11_u8, 12_u8, 12_u8, 13_u8, 13_u8];

fn read_bits ['s, 'i](state: &uniq 's InflateState, input: &'i buffer<u8>, count: own u32) -> own Result<u64, InflateError> reads('s 'i), writes('s), traps {
  loop @fill_bits {
    let enough: own Bool = ige<u32>(deref(state).bits, count);
    match enough {
      True() => {
        break @fill_bits;
      }
      False() => {
        let input_length: own u64 = len<u8>(deref(input));
        let input_done: own Bool = ige<u64>(deref(state).input_offset, input_length);
        match input_done {
          True() => {
            let error: own InflateError = Truncated();
            return Err(error: error);
          }
          False() => {
          }
        }
        let next_byte: own u8 = index<u8>(deref(input), deref(state).input_offset);
        let next_word: own u64 = cvt<u8, u64>(next_byte);
        let shifted: own u64 = ishl.wrap<u64>(next_word, deref(state).bits);
        set deref(state).hold = ior<u64>(deref(state).hold, shifted);
        set deref(state).bits = iadd.wrap<u32>(deref(state).bits, 8_u32);
        set deref(state).input_offset = iadd.wrap<u64>(deref(state).input_offset, 1_u64);
      }
    }
  }
  let mask_high: own u64 = ishl.wrap<u64>(1_u64, count);
  let mask: own u64 = isub.wrap<u64>(mask_high, 1_u64);
  let value: own u64 = iand<u64>(deref(state).hold, mask);
  set deref(state).hold = ishr.wrap<u64>(deref(state).hold, count);
  set deref(state).bits = isub.wrap<u32>(deref(state).bits, count);
  return Ok(value: value);
}

fn decode_fixed_symbol ['s, 'i](state: &uniq 's InflateState, input: &'i buffer<u8>) -> own Result<u64, InflateError> reads('s 'i), writes('s), traps {
  let code: own u64 = 0_u64;
  let first: own u64 = 0_u64;
  let symbol_index: own u64 = 0_u64;
  let bit_length: own u32 = 1_u32;
  let decoded: own u64 = 0_u64;
  loop @code_lengths {
    let bit: own u64 = 0_u64;
    region 'read_code_bit {
      match read_bits<'read_code_bit, 'read_code_bit>(state: &uniq 'read_code_bit deref(state), input: &'read_code_bit deref(input), count: 1_u32) {
        Ok(value: read_bit) => {
          set bit = read_bit;
        }
        Err(error: read_error) => {
          return Err(error: read_error);
        }
      }
    }
    set code = ior<u64>(code, bit);
    let count: own u64 = 0_u64;
    match ieq<u32>(bit_length, 7_u32) {
      True() => {
        set count = 24_u64;
      }
      False() => {
        match ieq<u32>(bit_length, 8_u32) {
          True() => {
            set count = 152_u64;
          }
          False() => {
            match ieq<u32>(bit_length, 9_u32) {
              True() => {
                set count = 112_u64;
              }
              False() => {
              }
            }
          }
        }
      }
    }
    let first_after_count: own u64 = iadd.wrap<u64>(first, count);
    let at_or_after_first: own Bool = ige<u64>(code, first);
    let before_end: own Bool = ilt<u64>(code, first_after_count);
    let found: own Bool = band<Bool>(at_or_after_first, before_end);
    match found {
      True() => {
        let offset: own u64 = isub.wrap<u64>(code, first);
        let ordered: own u64 = iadd.wrap<u64>(symbol_index, offset);
        match ilt<u64>(ordered, 24_u64) {
          True() => {
            set decoded = iadd.wrap<u64>(ordered, 256_u64);
            break @code_lengths;
          }
          False() => {
          }
        }
        match ilt<u64>(ordered, 168_u64) {
          True() => {
            set decoded = isub.wrap<u64>(ordered, 24_u64);
            break @code_lengths;
          }
          False() => {
          }
        }
        match ilt<u64>(ordered, 176_u64) {
          True() => {
            let tail: own u64 = isub.wrap<u64>(ordered, 168_u64);
            set decoded = iadd.wrap<u64>(tail, 280_u64);
            break @code_lengths;
          }
          False() => {
          }
        }
        set decoded = isub.wrap<u64>(ordered, 32_u64);
        break @code_lengths;
      }
      False() => {
      }
    }
    set symbol_index = iadd.wrap<u64>(symbol_index, count);
    set first = ishl.wrap<u64>(first_after_count, 1_u32);
    set code = ishl.wrap<u64>(code, 1_u32);
    match ieq<u32>(bit_length, 9_u32) {
      True() => {
        let error: own InflateError = InvalidHuffmanCode();
        return Err(error: error);
      }
      False() => {
      }
    }
    set bit_length = iadd.wrap<u32>(bit_length, 1_u32);
  }
  return Ok(value: decoded);
}

fn emit_byte ['s, 'o](state: &uniq 's InflateState, out: &uniq 'o buffer<u8>, value: own u8) -> own Result<unit, InflateError> reads('s 'o), writes('s 'o), traps {
  let output_length: own u64 = len<u8>(deref(out));
  let output_full: own Bool = ige<u64>(deref(state).output_offset, output_length);
  match output_full {
    True() => {
      let error: own InflateError = OutputFull();
      return Err(error: error);
    }
    False() => {
    }
  }
  set index<u8>(deref(out), deref(state).output_offset) = value;
  set deref(state).output_offset = iadd.wrap<u64>(deref(state).output_offset, 1_u64);
  return Ok(value: unit);
}

fn decode_fixed ['s, 'i, 'o](state: &uniq 's InflateState, input: &'i buffer<u8>, out: &uniq 'o buffer<u8>) -> own Result<unit, InflateError> reads('s 'i 'o), writes('s 'o), traps {
  loop @fixed_codes {
    let symbol: own u64 = 0_u64;
    region 'symbol_call {
      match decode_fixed_symbol<'symbol_call, 'symbol_call>(state: &uniq 'symbol_call deref(state), input: &'symbol_call deref(input)) {
        Ok(value: decoded_symbol) => {
          set symbol = decoded_symbol;
        }
        Err(error: symbol_error) => {
          return Err(error: symbol_error);
        }
      }
    }
    let literal: own Bool = ile<u64>(symbol, 255_u64);
    match literal {
      True() => {
        match cvt<u64, u8>(symbol) {
          Ok(value: byte) => {
            region 'literal_emit {
              match emit_byte<'literal_emit, 'literal_emit>(state: &uniq 'literal_emit deref(state), out: &uniq 'literal_emit deref(out), value: byte) {
                Ok(value: emitted) => {
                }
                Err(error: emit_error) => {
                  return Err(error: emit_error);
                }
              }
            }
          }
          Err(error: conversion_error) => {
            let error: own InflateError = InvalidHuffmanCode();
            return Err(error: error);
          }
        }
      }
      False() => {
        let end_of_block: own Bool = ieq<u64>(symbol, 256_u64);
        match end_of_block {
          True() => {
            break @fixed_codes;
          }
          False() => {
            let invalid_length_symbol: own Bool = ige<u64>(symbol, 286_u64);
            match invalid_length_symbol {
              True() => {
                let error: own InflateError = InvalidHuffmanCode();
                return Err(error: error);
              }
              False() => {
              }
            }
            let length_index: own u64 = isub.wrap<u64>(symbol, 257_u64);
            let length_base_word: own u16 = index<u16>(length_bases, length_index);
            let length_base: own u64 = cvt<u16, u64>(length_base_word);
            let length_extra_byte: own u8 = index<u8>(length_extras, length_index);
            let length_extra_count: own u32 = cvt<u8, u32>(length_extra_byte);
            let length_extra: own u64 = 0_u64;
            region 'length_extra_call {
              match read_bits<'length_extra_call, 'length_extra_call>(state: &uniq 'length_extra_call deref(state), input: &'length_extra_call deref(input), count: length_extra_count) {
                Ok(value: extra) => {
                  set length_extra = extra;
                }
                Err(error: length_error) => {
                  return Err(error: length_error);
                }
              }
            }
            let copy_length: own u64 = iadd.wrap<u64>(length_base, length_extra);
            let distance_symbol: own u64 = 0_u64;
            region 'distance_symbol_call {
              match read_bits<'distance_symbol_call, 'distance_symbol_call>(state: &uniq 'distance_symbol_call deref(state), input: &'distance_symbol_call deref(input), count: 5_u32) {
                Ok(value: distance_code) => {
                  set distance_symbol = distance_code;
                }
                Err(error: distance_symbol_error) => {
                  return Err(error: distance_symbol_error);
                }
              }
            }
            let invalid_distance_symbol: own Bool = ige<u64>(distance_symbol, 30_u64);
            match invalid_distance_symbol {
              True() => {
                let error: own InflateError = InvalidDistance();
                return Err(error: error);
              }
              False() => {
              }
            }
            let distance_base_word: own u16 = index<u16>(distance_bases, distance_symbol);
            let distance_base: own u64 = cvt<u16, u64>(distance_base_word);
            let distance_extra_byte: own u8 = index<u8>(distance_extras, distance_symbol);
            let distance_extra_count: own u32 = cvt<u8, u32>(distance_extra_byte);
            let distance_extra: own u64 = 0_u64;
            region 'distance_extra_call {
              match read_bits<'distance_extra_call, 'distance_extra_call>(state: &uniq 'distance_extra_call deref(state), input: &'distance_extra_call deref(input), count: distance_extra_count) {
                Ok(value: extra) => {
                  set distance_extra = extra;
                }
                Err(error: distance_error) => {
                  return Err(error: distance_error);
                }
              }
            }
            let distance: own u64 = iadd.wrap<u64>(distance_base, distance_extra);
            let before_history: own Bool = ilt<u64>(deref(state).output_offset, distance);
            match before_history {
              True() => {
                let error: own InflateError = InvalidDistance();
                return Err(error: error);
              }
              False() => {
              }
            }
            let copied: own u64 = 0_u64;
            loop @copy_match {
              let copy_done: own Bool = ieq<u64>(copied, copy_length);
              match copy_done {
                True() => {
                  break @copy_match;
                }
                False() => {
                  let source_index: own u64 = isub.wrap<u64>(deref(state).output_offset, distance);
                  let byte: own u8 = index<u8>(deref(out), source_index);
                  region 'match_emit {
                    match emit_byte<'match_emit, 'match_emit>(state: &uniq 'match_emit deref(state), out: &uniq 'match_emit deref(out), value: byte) {
                      Ok(value: emitted) => {
                      }
                      Err(error: emit_error) => {
                        return Err(error: emit_error);
                      }
                    }
                  }
                  set copied = iadd.wrap<u64>(copied, 1_u64);
                }
              }
            }
          }
        }
      }
    }
  }
  return Ok(value: unit);
}

fn inflate ['r](out: &uniq 'r buffer<u8>, input: own buffer<u8>) -> own Result<u64, InflateError> reads('r), writes('r), traps {
  let input_length: own u64 = len<u8>(input);
  let output_length: own u64 = len<u8>(deref(out));
  let state: own InflateState = InflateState(input_offset: 0_u64, output_offset: 0_u64, hold: 0_u64, bits: 0_u32);
  loop @blocks {
    let final_value: own u64 = 0_u64;
    region 'final_call {
      match read_bits<'final_call, 'final_call>(state: &uniq 'final_call state, input: &'final_call input, count: 1_u32) {
        Ok(value: final_bit) => {
          set final_value = final_bit;
        }
        Err(error: final_error) => {
          return Err(error: final_error);
        }
      }
    }
    let final_block: own Bool = ieq<u64>(final_value, 1_u64);
    let block_type: own u64 = 0_u64;
    region 'block_type_call {
      match read_bits<'block_type_call, 'block_type_call>(state: &uniq 'block_type_call state, input: &'block_type_call input, count: 2_u32) {
        Ok(value: block_type_bits) => {
          set block_type = block_type_bits;
        }
        Err(error: block_type_error) => {
          return Err(error: block_type_error);
        }
      }
    }
    let stored_block: own Bool = ieq<u64>(block_type, 0_u64);
    match stored_block {
      True() => {
        set state.hold = 0_u64;
        set state.bits = 0_u32;
        let length_bytes_remaining: own u64 = isub.wrap<u64>(input_length, state.input_offset);
        let length_truncated: own Bool = ilt<u64>(length_bytes_remaining, 4_u64);
        match length_truncated {
          True() => {
            let error: own InflateError = Truncated();
            return Err(error: error);
          }
          False() => {
          }
        }
        let len_high_offset: own u64 = iadd.wrap<u64>(state.input_offset, 1_u64);
        let nlen_low_offset: own u64 = iadd.wrap<u64>(state.input_offset, 2_u64);
        let nlen_high_offset: own u64 = iadd.wrap<u64>(state.input_offset, 3_u64);
        let len_low_byte: own u8 = index<u8>(input, state.input_offset);
        let len_high_byte: own u8 = index<u8>(input, len_high_offset);
        let nlen_low_byte: own u8 = index<u8>(input, nlen_low_offset);
        let nlen_high_byte: own u8 = index<u8>(input, nlen_high_offset);
        set state.input_offset = iadd.wrap<u64>(state.input_offset, 4_u64);
        let len_low: own u16 = cvt<u8, u16>(len_low_byte);
        let len_high_word: own u16 = cvt<u8, u16>(len_high_byte);
        let len_high: own u16 = ishl.wrap<u16>(len_high_word, 8_u32);
        let stored_length: own u16 = ior<u16>(len_low, len_high);
        let nlen_low: own u16 = cvt<u8, u16>(nlen_low_byte);
        let nlen_high_word: own u16 = cvt<u8, u16>(nlen_high_byte);
        let nlen_high: own u16 = ishl.wrap<u16>(nlen_high_word, 8_u32);
        let stored_complement: own u16 = ior<u16>(nlen_low, nlen_high);
        let expected_complement: own u16 = inot<u16>(stored_length);
        let complement_valid: own Bool = ieq<u16>(stored_complement, expected_complement);
        match complement_valid {
          True() => {
          }
          False() => {
            let error: own InflateError = InvalidStoredLength();
            return Err(error: error);
          }
        }
        let copy_length: own u64 = cvt<u16, u64>(stored_length);
        let input_remaining: own u64 = isub.wrap<u64>(input_length, state.input_offset);
        let input_short: own Bool = ilt<u64>(input_remaining, copy_length);
        match input_short {
          True() => {
            let error: own InflateError = Truncated();
            return Err(error: error);
          }
          False() => {
          }
        }
        let output_remaining: own u64 = isub.wrap<u64>(output_length, state.output_offset);
        let output_short: own Bool = ilt<u64>(output_remaining, copy_length);
        match output_short {
          True() => {
            let error: own InflateError = OutputFull();
            return Err(error: error);
          }
          False() => {
          }
        }
        let copied: own u64 = 0_u64;
        loop @copy_stored {
          let copy_done: own Bool = ieq<u64>(copied, copy_length);
          match copy_done {
            True() => {
              break @copy_stored;
            }
            False() => {
              let source_index: own u64 = iadd.wrap<u64>(state.input_offset, copied);
              let byte: own u8 = index<u8>(input, source_index);
              region 'stored_emit {
                match emit_byte<'stored_emit, 'stored_emit>(state: &uniq 'stored_emit state, out: &uniq 'stored_emit deref(out), value: byte) {
                  Ok(value: emitted) => {
                  }
                  Err(error: emit_error) => {
                    return Err(error: emit_error);
                  }
                }
              }
              set copied = iadd.wrap<u64>(copied, 1_u64);
            }
          }
        }
        set state.input_offset = iadd.wrap<u64>(state.input_offset, copy_length);
      }
      False() => {
        let fixed_block: own Bool = ieq<u64>(block_type, 1_u64);
        match fixed_block {
          True() => {
            region 'fixed_call {
              match decode_fixed<'fixed_call, 'fixed_call, 'fixed_call>(state: &uniq 'fixed_call state, input: &'fixed_call input, out: &uniq 'fixed_call deref(out)) {
                Ok(value: decoded) => {
                }
                Err(error: decode_error) => {
                  return Err(error: decode_error);
                }
              }
            }
          }
          False() => {
            let error: own InflateError = UnsupportedBlockType();
            return Err(error: error);
          }
        }
      }
    }
    match final_block {
      True() => {
        break @blocks;
      }
      False() => {
      }
    }
  }
  return Ok(value: state.output_offset);
}
