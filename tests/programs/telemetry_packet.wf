fn store_u32_be ['o](out: &uniq 'o buffer<u8>, offset: own u64, value: own u32) -> own Result<unit, NarrowError> writes('o), traps {
  let first_word: own u32 = ishr.wrap<u32>(value, 24_u32);
  let second_shifted: own u32 = ishr.wrap<u32>(value, 16_u32);
  let second_word: own u32 = iand<u32>(second_shifted, 255_u32);
  let third_shifted: own u32 = ishr.wrap<u32>(value, 8_u32);
  let third_word: own u32 = iand<u32>(third_shifted, 255_u32);
  let fourth_word: own u32 = iand<u32>(value, 255_u32);
  let first: own u8 = propagate cvt<u32, u8>(first_word);
  let second: own u8 = propagate cvt<u32, u8>(second_word);
  let third: own u8 = propagate cvt<u32, u8>(third_word);
  let fourth: own u8 = propagate cvt<u32, u8>(fourth_word);
  let second_offset: own u64 = iadd.wrap<u64>(offset, 1_u64);
  let third_offset: own u64 = iadd.wrap<u64>(offset, 2_u64);
  let fourth_offset: own u64 = iadd.wrap<u64>(offset, 3_u64);
  set index<u8>(deref(out), offset) = first;
  set index<u8>(deref(out), second_offset) = second;
  set index<u8>(deref(out), third_offset) = third;
  set index<u8>(deref(out), fourth_offset) = fourth;
  return Ok(value: unit);
}

fn load_u32_be ['i](input: &'i buffer<u8>, offset: own u64) -> own u32 reads('i), traps {
  let second_offset: own u64 = iadd.wrap<u64>(offset, 1_u64);
  let third_offset: own u64 = iadd.wrap<u64>(offset, 2_u64);
  let fourth_offset: own u64 = iadd.wrap<u64>(offset, 3_u64);
  let first_byte: own u8 = index<u8>(deref(input), offset);
  let second_byte: own u8 = index<u8>(deref(input), second_offset);
  let third_byte: own u8 = index<u8>(deref(input), third_offset);
  let fourth_byte: own u8 = index<u8>(deref(input), fourth_offset);
  let first: own u32 = cvt<u8, u32>(first_byte);
  let second: own u32 = cvt<u8, u32>(second_byte);
  let third: own u32 = cvt<u8, u32>(third_byte);
  let fourth: own u32 = cvt<u8, u32>(fourth_byte);
  let first_shifted: own u32 = ishl.wrap<u32>(first, 24_u32);
  let second_shifted: own u32 = ishl.wrap<u32>(second, 16_u32);
  let third_shifted: own u32 = ishl.wrap<u32>(third, 8_u32);
  let first_second: own u32 = ior<u32>(first_shifted, second_shifted);
  let first_third: own u32 = ior<u32>(first_second, third_shifted);
  return ior<u32>(first_third, fourth);
}

fn main() -> own unit allocates(heap), traps {
  let packet: own buffer<u8> = buffer_new<u8>(12_u64, 0_u8);
  let temperature: own f32 = 36.5_f32;
  let temperature_bits: own u32 = reinterpret<f32, u32>(temperature);
  region 'temperature_write {
    let stored: own Result<unit, NarrowError> = store_u32_be<'temperature_write>(out: &uniq 'temperature_write packet, offset: 0_u64, value: temperature_bits);
    match move stored {
      Ok(value: success) => {
      }
      Err(error: narrow) => {
        check False() else trap "temperature encoding";
      }
    }
  }
  let negative_zero: own f32 = -0.0_f32;
  let negative_zero_bits: own u32 = reinterpret<f32, u32>(negative_zero);
  region 'zero_write {
    let stored: own Result<unit, NarrowError> = store_u32_be<'zero_write>(out: &uniq 'zero_write packet, offset: 4_u64, value: negative_zero_bits);
    match move stored {
      Ok(value: success) => {
      }
      Err(error: narrow) => {
        check False() else trap "negative zero encoding";
      }
    }
  }
  let nan: own f32 = fnan<f32>();
  let nan_bits: own u32 = reinterpret<f32, u32>(nan);
  region 'nan_write {
    let stored: own Result<unit, NarrowError> = store_u32_be<'nan_write>(out: &uniq 'nan_write packet, offset: 8_u64, value: nan_bits);
    match move stored {
      Ok(value: success) => {
      }
      Err(error: narrow) => {
        check False() else trap "NaN encoding";
      }
    }
  }
  region 'temperature_read {
    let bits: own u32 = load_u32_be<'temperature_read>(input: &'temperature_read packet, offset: 0_u64);
    let decoded: own f32 = reinterpret<u32, f32>(bits);
    check feq<f32>(decoded, temperature) else trap "temperature round trip";
  }
  region 'zero_read {
    let bits: own u32 = load_u32_be<'zero_read>(input: &'zero_read packet, offset: 4_u64);
    let decoded: own f32 = reinterpret<u32, f32>(bits);
    let reciprocal: own f32 = fdiv.strict<f32>(1.0_f32, decoded);
    let infinity: own f32 = finf<f32>();
    let negative_infinity: own f32 = fneg<f32>(infinity);
    check feq<f32>(reciprocal, negative_infinity) else trap "negative zero sign";
  }
  region 'nan_read {
    let bits: own u32 = load_u32_be<'nan_read>(input: &'nan_read packet, offset: 8_u64);
    let decoded: own f32 = reinterpret<u32, f32>(bits);
    check fne<f32>(decoded, decoded) else trap "NaN round trip";
  }
  return unit;
}
