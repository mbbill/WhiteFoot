struct Pair<T: Int> {
  left: T;
  right: T;
}

enum Choice<T: Int> {
  Missing();
  Present(value: T);
}

struct Packet<const n: u64> {
  bytes: array<u8, n>;
}

struct Holder<T> {
  value: T;
}

struct Wrapped<T: Int> {
  value: Option<T>;
}

fn duplicate<T: Int>(value: own T) -> own Pair<T> pure {
  return Pair<T>(left: value, right: value);
}

fn present<T: Int>(value: own T) -> own Choice<T> pure {
  return Present<T>(value: value);
}

fn checked_sum<T: Int>(left: own T, right: own T) -> own Result<T, Overflow> pure {
  return iadd.checked<T>(left, right);
}

fn main() -> own unit traps {
  let small: own Pair<u8> = duplicate<u8>(value: 7_u8);
  let wide: own Pair<i64> = duplicate<i64>(value: -9_i64);
  let small_left: own u8 = small.left;
  let wide_right: own i64 = wide.right;
  check ieq<u8>(small_left, 7_u8) else trap "small generic struct";
  check ieq<i64>(wide_right, -9_i64) else trap "wide generic struct";
  let small_choice: own Choice<u8> = present<u8>(value: 3_u8);
  match small_choice {
    Missing() => {
      check False() else trap "unexpected small choice";
    }
    Present(value: observed) => {
      check ieq<u8>(observed, 3_u8) else trap "small generic enum";
    }
  }
  let wide_choice: own Choice<i64> = present<i64>(value: -5_i64);
  match wide_choice {
    Missing() => {
      check False() else trap "unexpected wide choice";
    }
    Present(value: observed) => {
      check ieq<i64>(observed, -5_i64) else trap "wide generic enum";
    }
  }
  let sum: own Result<u8, Overflow> = checked_sum<u8>(left: 1_u8, right: 2_u8);
  match sum {
    Ok(value: observed) => {
      check ieq<u8>(observed, 3_u8) else trap "checked generic sum";
    }
    Err(error: overflow) => {
      check False() else trap "unexpected checked overflow";
    }
  }
  let overflowed: own Result<u8, Overflow> = checked_sum<u8>(left: 255_u8, right: 1_u8);
  match overflowed {
    Ok(value: observed) => {
      check False() else trap "missing checked overflow";
    }
    Err(error: overflow) => {
    }
  }
  let wide_sum: own Result<i64, Overflow> = checked_sum<i64>(left: -4_i64, right: 9_i64);
  match wide_sum {
    Ok(value: observed) => {
      check ieq<i64>(observed, 5_i64) else trap "wide checked generic sum";
    }
    Err(error: overflow) => {
      check False() else trap "unexpected wide overflow";
    }
  }
  let optional: own Option<u8> = Some(value: 19_u8);
  let wrapped: own Wrapped<u8> = Wrapped<u8>(value: move optional);
  let recovered_optional: own Option<u8> = move wrapped.value;
  match recovered_optional {
    None() => {
      check False() else trap "missing wrapped option";
    }
    Some(value: observed) => {
      check ieq<u8>(observed, 19_u8) else trap "wrapped generic option";
    }
  }
  let bytes: own array<u8, 2> = array_new<u8, 2>(11_u8);
  let packet: own Packet<2> = Packet<2>(bytes: move bytes);
  let holder: own Holder<Packet<2>> = Holder<Packet<2>>(value: move packet);
  let recovered_packet: own Packet<2> = move holder.value;
  let recovered_bytes: own array<u8, 2> = move recovered_packet.bytes;
  let recovered: own u8 = index<u8>(recovered_bytes, 1_u64);
  check ieq<u8>(recovered, 11_u8) else trap "nested const generic nominal";
  return unit;
}
