const fixed_phrase_expected: array<u8, 17> = [104_u8, 101_u8, 108_u8, 108_u8, 111_u8, 32_u8, 104_u8, 101_u8, 108_u8, 108_u8, 111_u8, 32_u8, 104_u8, 101_u8, 108_u8, 108_u8, 111_u8];

fn error_code(error: own InflateError) -> own u8 pure {
  match error {
    Truncated() => {
      return 1_u8;
    }
    InvalidStoredLength() => {
      return 2_u8;
    }
    InvalidHuffmanCode() => {
      return 3_u8;
    }
    InvalidDistance() => {
      return 4_u8;
    }
    OutputFull() => {
      return 5_u8;
    }
    UnsupportedBlockType() => {
      return 6_u8;
    }
  }
}

fn main() -> own unit allocates(heap), traps {
  let valid_input: own buffer<u8> = buffer_new<u8>(15_u64, 0_u8);
  set index<u8>(valid_input, 0_u64) = 0_u8;
  set index<u8>(valid_input, 1_u64) = 2_u8;
  set index<u8>(valid_input, 2_u64) = 0_u8;
  set index<u8>(valid_input, 3_u64) = 253_u8;
  set index<u8>(valid_input, 4_u64) = 255_u8;
  set index<u8>(valid_input, 5_u64) = 104_u8;
  set index<u8>(valid_input, 6_u64) = 101_u8;
  set index<u8>(valid_input, 7_u64) = 1_u8;
  set index<u8>(valid_input, 8_u64) = 3_u8;
  set index<u8>(valid_input, 9_u64) = 0_u8;
  set index<u8>(valid_input, 10_u64) = 252_u8;
  set index<u8>(valid_input, 11_u64) = 255_u8;
  set index<u8>(valid_input, 12_u64) = 108_u8;
  set index<u8>(valid_input, 13_u64) = 108_u8;
  set index<u8>(valid_input, 14_u64) = 111_u8;
  let valid_output: own buffer<u8> = buffer_new<u8>(5_u64, 0_u8);
  region 'valid_region {
    let valid_result: own Result<u64, InflateError> = inflate<'valid_region>(out: &uniq 'valid_region valid_output, input: move valid_input);
    match move valid_result {
      Ok(value: valid_length) => {
        check ieq<u64>(valid_length, 5_u64) else trap "stored output length";
      }
      Err(error: valid_error) => {
        check False() else trap "stored stream rejected";
      }
    }
  }
  let valid_zero: own u8 = index<u8>(valid_output, 0_u64);
  let valid_one: own u8 = index<u8>(valid_output, 1_u64);
  let valid_two: own u8 = index<u8>(valid_output, 2_u64);
  let valid_three: own u8 = index<u8>(valid_output, 3_u64);
  let valid_four: own u8 = index<u8>(valid_output, 4_u64);
  check ieq<u8>(valid_zero, 104_u8) else trap "stored byte zero";
  check ieq<u8>(valid_one, 101_u8) else trap "stored byte one";
  check ieq<u8>(valid_two, 108_u8) else trap "stored byte two";
  check ieq<u8>(valid_three, 108_u8) else trap "stored byte three";
  check ieq<u8>(valid_four, 111_u8) else trap "stored byte four";
  let invalid_length_input: own buffer<u8> = buffer_new<u8>(6_u64, 0_u8);
  set index<u8>(invalid_length_input, 0_u64) = 1_u8;
  set index<u8>(invalid_length_input, 1_u64) = 1_u8;
  set index<u8>(invalid_length_input, 2_u64) = 0_u8;
  set index<u8>(invalid_length_input, 3_u64) = 255_u8;
  set index<u8>(invalid_length_input, 4_u64) = 255_u8;
  set index<u8>(invalid_length_input, 5_u64) = 65_u8;
  let invalid_length_output: own buffer<u8> = buffer_new<u8>(1_u64, 9_u8);
  region 'invalid_length_region {
    let invalid_length_result: own Result<u64, InflateError> = inflate<'invalid_length_region>(out: &uniq 'invalid_length_region invalid_length_output, input: move invalid_length_input);
    match move invalid_length_result {
      Ok(value: invalid_length_value) => {
        check False() else trap "invalid stored length accepted";
      }
      Err(error: invalid_length_error) => {
        match invalid_length_error {
          InvalidStoredLength() => {
          }
          Truncated() => {
            check False() else trap "invalid length became truncation";
          }
          OutputFull() => {
            check False() else trap "invalid length became output full";
          }
          InvalidHuffmanCode() => {
            check False() else trap "invalid length became Huffman error";
          }
          InvalidDistance() => {
            check False() else trap "invalid length became distance error";
          }
          UnsupportedBlockType() => {
            check False() else trap "invalid length became block type";
          }
        }
      }
    }
  }
  let invalid_length_sentinel: own u8 = index<u8>(invalid_length_output, 0_u64);
  check ieq<u8>(invalid_length_sentinel, 9_u8) else trap "invalid length wrote output";
  let truncated_input: own buffer<u8> = buffer_new<u8>(4_u64, 0_u8);
  set index<u8>(truncated_input, 0_u64) = 1_u8;
  set index<u8>(truncated_input, 1_u64) = 2_u8;
  set index<u8>(truncated_input, 2_u64) = 0_u8;
  set index<u8>(truncated_input, 3_u64) = 253_u8;
  let truncated_output: own buffer<u8> = buffer_new<u8>(2_u64, 7_u8);
  region 'truncated_region {
    let truncated_result: own Result<u64, InflateError> = inflate<'truncated_region>(out: &uniq 'truncated_region truncated_output, input: move truncated_input);
    match move truncated_result {
      Ok(value: truncated_value) => {
        check False() else trap "truncated stream accepted";
      }
      Err(error: truncated_error) => {
        match truncated_error {
          Truncated() => {
          }
          InvalidStoredLength() => {
            check False() else trap "truncation became invalid length";
          }
          OutputFull() => {
            check False() else trap "truncation became output full";
          }
          InvalidHuffmanCode() => {
            check False() else trap "truncation became Huffman error";
          }
          InvalidDistance() => {
            check False() else trap "truncation became distance error";
          }
          UnsupportedBlockType() => {
            check False() else trap "truncation became block type";
          }
        }
      }
    }
  }
  let truncated_sentinel: own u8 = index<u8>(truncated_output, 0_u64);
  check ieq<u8>(truncated_sentinel, 7_u8) else trap "truncation wrote output";
  let full_input: own buffer<u8> = buffer_new<u8>(7_u64, 0_u8);
  set index<u8>(full_input, 0_u64) = 1_u8;
  set index<u8>(full_input, 1_u64) = 2_u8;
  set index<u8>(full_input, 2_u64) = 0_u8;
  set index<u8>(full_input, 3_u64) = 253_u8;
  set index<u8>(full_input, 4_u64) = 255_u8;
  set index<u8>(full_input, 5_u64) = 65_u8;
  set index<u8>(full_input, 6_u64) = 66_u8;
  let full_output: own buffer<u8> = buffer_new<u8>(1_u64, 11_u8);
  region 'full_region {
    let full_result: own Result<u64, InflateError> = inflate<'full_region>(out: &uniq 'full_region full_output, input: move full_input);
    match move full_result {
      Ok(value: full_value) => {
        check False() else trap "undersized output accepted";
      }
      Err(error: full_error) => {
        match full_error {
          OutputFull() => {
          }
          Truncated() => {
            check False() else trap "output full became truncation";
          }
          InvalidStoredLength() => {
            check False() else trap "output full became invalid length";
          }
          InvalidHuffmanCode() => {
            check False() else trap "output full became Huffman error";
          }
          InvalidDistance() => {
            check False() else trap "output full became distance error";
          }
          UnsupportedBlockType() => {
            check False() else trap "output full became block type";
          }
        }
      }
    }
  }
  let full_sentinel: own u8 = index<u8>(full_output, 0_u64);
  check ieq<u8>(full_sentinel, 11_u8) else trap "output full wrote prefix";
  let fixed_literal_input: own buffer<u8> = buffer_new<u8>(7_u64, 0_u8);
  set index<u8>(fixed_literal_input, 0_u64) = 203_u8;
  set index<u8>(fixed_literal_input, 1_u64) = 72_u8;
  set index<u8>(fixed_literal_input, 2_u64) = 205_u8;
  set index<u8>(fixed_literal_input, 3_u64) = 201_u8;
  set index<u8>(fixed_literal_input, 4_u64) = 201_u8;
  set index<u8>(fixed_literal_input, 5_u64) = 7_u8;
  set index<u8>(fixed_literal_input, 6_u64) = 0_u8;
  let fixed_literal_output: own buffer<u8> = buffer_new<u8>(5_u64, 0_u8);
  region 'fixed_literal_region {
    let fixed_literal_result: own Result<u64, InflateError> = inflate<'fixed_literal_region>(out: &uniq 'fixed_literal_region fixed_literal_output, input: move fixed_literal_input);
    match move fixed_literal_result {
      Ok(value: fixed_literal_length) => {
        check ieq<u64>(fixed_literal_length, 5_u64) else trap "fixed literal output length";
      }
      Err(error: fixed_literal_error) => {
        check False() else trap "fixed literal stream rejected";
      }
    }
  }
  let fixed_literal_zero: own u8 = index<u8>(fixed_literal_output, 0_u64);
  let fixed_literal_one: own u8 = index<u8>(fixed_literal_output, 1_u64);
  let fixed_literal_two: own u8 = index<u8>(fixed_literal_output, 2_u64);
  let fixed_literal_three: own u8 = index<u8>(fixed_literal_output, 3_u64);
  let fixed_literal_four: own u8 = index<u8>(fixed_literal_output, 4_u64);
  check ieq<u8>(fixed_literal_zero, 104_u8) else trap "fixed literal byte zero";
  check ieq<u8>(fixed_literal_one, 101_u8) else trap "fixed literal byte one";
  check ieq<u8>(fixed_literal_two, 108_u8) else trap "fixed literal byte two";
  check ieq<u8>(fixed_literal_three, 108_u8) else trap "fixed literal byte three";
  check ieq<u8>(fixed_literal_four, 111_u8) else trap "fixed literal byte four";
  let fixed_match_input: own buffer<u8> = buffer_new<u8>(5_u64, 0_u8);
  set index<u8>(fixed_match_input, 0_u64) = 75_u8;
  set index<u8>(fixed_match_input, 1_u64) = 76_u8;
  set index<u8>(fixed_match_input, 2_u64) = 68_u8;
  set index<u8>(fixed_match_input, 3_u64) = 5_u8;
  set index<u8>(fixed_match_input, 4_u64) = 0_u8;
  let fixed_match_output: own buffer<u8> = buffer_new<u8>(16_u64, 0_u8);
  region 'fixed_match_region {
    let fixed_match_result: own Result<u64, InflateError> = inflate<'fixed_match_region>(out: &uniq 'fixed_match_region fixed_match_output, input: move fixed_match_input);
    match move fixed_match_result {
      Ok(value: fixed_match_length) => {
        check ieq<u64>(fixed_match_length, 16_u64) else trap "fixed match output length";
      }
      Err(error: fixed_match_error) => {
        check False() else trap "fixed match stream rejected";
      }
    }
  }
  let fixed_match_index: own u64 = 0_u64;
  loop @check_fixed_match {
    let fixed_match_done: own Bool = ieq<u64>(fixed_match_index, 16_u64);
    match fixed_match_done {
      True() => {
        break @check_fixed_match;
      }
      False() => {
        let fixed_match_byte: own u8 = index<u8>(fixed_match_output, fixed_match_index);
        check ieq<u8>(fixed_match_byte, 97_u8) else trap "fixed overlapping match byte";
        set fixed_match_index = iadd.wrap<u64>(fixed_match_index, 1_u64);
      }
    }
  }
  let fixed_phrase_input: own buffer<u8> = buffer_new<u8>(10_u64, 0_u8);
  set index<u8>(fixed_phrase_input, 0_u64) = 203_u8;
  set index<u8>(fixed_phrase_input, 1_u64) = 72_u8;
  set index<u8>(fixed_phrase_input, 2_u64) = 205_u8;
  set index<u8>(fixed_phrase_input, 3_u64) = 201_u8;
  set index<u8>(fixed_phrase_input, 4_u64) = 201_u8;
  set index<u8>(fixed_phrase_input, 5_u64) = 87_u8;
  set index<u8>(fixed_phrase_input, 6_u64) = 200_u8;
  set index<u8>(fixed_phrase_input, 7_u64) = 64_u8;
  set index<u8>(fixed_phrase_input, 8_u64) = 144_u8;
  set index<u8>(fixed_phrase_input, 9_u64) = 0_u8;
  let fixed_phrase_output: own buffer<u8> = buffer_new<u8>(17_u64, 0_u8);
  region 'fixed_phrase_region {
    let fixed_phrase_result: own Result<u64, InflateError> = inflate<'fixed_phrase_region>(out: &uniq 'fixed_phrase_region fixed_phrase_output, input: move fixed_phrase_input);
    match move fixed_phrase_result {
      Ok(value: fixed_phrase_length) => {
        check ieq<u64>(fixed_phrase_length, 17_u64) else trap "fixed phrase output length";
      }
      Err(error: fixed_phrase_error) => {
        check False() else trap "fixed phrase stream rejected";
      }
    }
  }
  let fixed_phrase_index: own u64 = 0_u64;
  loop @check_fixed_phrase {
    let fixed_phrase_done: own Bool = ieq<u64>(fixed_phrase_index, 17_u64);
    match fixed_phrase_done {
      True() => {
        break @check_fixed_phrase;
      }
      False() => {
        let fixed_phrase_actual: own u8 = index<u8>(fixed_phrase_output, fixed_phrase_index);
        let fixed_phrase_wanted: own u8 = index<u8>(fixed_phrase_expected, fixed_phrase_index);
        check ieq<u8>(fixed_phrase_actual, fixed_phrase_wanted) else trap "fixed distance-extra byte";
        set fixed_phrase_index = iadd.wrap<u64>(fixed_phrase_index, 1_u64);
      }
    }
  }
  let fixed_truncated_input: own buffer<u8> = buffer_new<u8>(1_u64, 203_u8);
  let fixed_truncated_output: own buffer<u8> = buffer_new<u8>(5_u64, 0_u8);
  region 'fixed_truncated_region {
    let fixed_truncated_result: own Result<u64, InflateError> = inflate<'fixed_truncated_region>(out: &uniq 'fixed_truncated_region fixed_truncated_output, input: move fixed_truncated_input);
    match move fixed_truncated_result {
      Ok(value: fixed_truncated_length) => {
        check False() else trap "truncated fixed stream accepted";
      }
      Err(error: fixed_truncated_error) => {
        let fixed_truncated_code: own u8 = error_code(error: fixed_truncated_error);
        check ieq<u8>(fixed_truncated_code, 1_u8) else trap "truncated fixed stream misclassified";
      }
    }
  }
  let invalid_huffman_input: own buffer<u8> = buffer_new<u8>(2_u64, 0_u8);
  set index<u8>(invalid_huffman_input, 0_u64) = 27_u8;
  set index<u8>(invalid_huffman_input, 1_u64) = 3_u8;
  let invalid_huffman_output: own buffer<u8> = buffer_new<u8>(1_u64, 0_u8);
  region 'invalid_huffman_region {
    let invalid_huffman_result: own Result<u64, InflateError> = inflate<'invalid_huffman_region>(out: &uniq 'invalid_huffman_region invalid_huffman_output, input: move invalid_huffman_input);
    match move invalid_huffman_result {
      Ok(value: invalid_huffman_length) => {
        check False() else trap "reserved fixed symbol accepted";
      }
      Err(error: invalid_huffman_error) => {
        let invalid_huffman_code: own u8 = error_code(error: invalid_huffman_error);
        check ieq<u8>(invalid_huffman_code, 3_u8) else trap "reserved fixed symbol misclassified";
      }
    }
  }
  let invalid_distance_input: own buffer<u8> = buffer_new<u8>(2_u64, 0_u8);
  set index<u8>(invalid_distance_input, 0_u64) = 3_u8;
  set index<u8>(invalid_distance_input, 1_u64) = 2_u8;
  let invalid_distance_output: own buffer<u8> = buffer_new<u8>(3_u64, 0_u8);
  region 'invalid_distance_region {
    let invalid_distance_result: own Result<u64, InflateError> = inflate<'invalid_distance_region>(out: &uniq 'invalid_distance_region invalid_distance_output, input: move invalid_distance_input);
    match move invalid_distance_result {
      Ok(value: invalid_distance_length) => {
        check False() else trap "distance before history accepted";
      }
      Err(error: invalid_distance_error) => {
        let invalid_distance_code: own u8 = error_code(error: invalid_distance_error);
        check ieq<u8>(invalid_distance_code, 4_u8) else trap "distance before history misclassified";
      }
    }
  }
  let fixed_full_input: own buffer<u8> = buffer_new<u8>(7_u64, 0_u8);
  set index<u8>(fixed_full_input, 0_u64) = 203_u8;
  set index<u8>(fixed_full_input, 1_u64) = 72_u8;
  set index<u8>(fixed_full_input, 2_u64) = 205_u8;
  set index<u8>(fixed_full_input, 3_u64) = 201_u8;
  set index<u8>(fixed_full_input, 4_u64) = 201_u8;
  set index<u8>(fixed_full_input, 5_u64) = 7_u8;
  set index<u8>(fixed_full_input, 6_u64) = 0_u8;
  let fixed_full_output: own buffer<u8> = buffer_new<u8>(4_u64, 0_u8);
  region 'fixed_full_region {
    let fixed_full_result: own Result<u64, InflateError> = inflate<'fixed_full_region>(out: &uniq 'fixed_full_region fixed_full_output, input: move fixed_full_input);
    match move fixed_full_result {
      Ok(value: fixed_full_length) => {
        check False() else trap "undersized fixed output accepted";
      }
      Err(error: fixed_full_error) => {
        let fixed_full_code: own u8 = error_code(error: fixed_full_error);
        check ieq<u8>(fixed_full_code, 5_u8) else trap "fixed output shortage misclassified";
      }
    }
  }
  return unit;
}
