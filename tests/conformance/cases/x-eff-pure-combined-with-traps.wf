fn f (x: own i32) -> own i32 pure, traps {
  doc "pure combined with traps [EFF-1]; pure is the empty row.";
  check ieq<i32>(x, x) else trap "x";
  return x;
}

fn main () -> own unit traps {
  doc "Driver.";
  let a: own i32 = f(x: 7_i32);
  check ieq<i32>(a, 7_i32) else trap "x";
  return unit;
}
