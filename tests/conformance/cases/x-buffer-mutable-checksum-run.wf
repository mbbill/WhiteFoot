fn main() -> own unit allocates(heap), traps {
  doc "A runtime-length buffer is allocated, filled, folded, and released through checked indexed access.";
  let values: own buffer<u64> = buffer_new<u64>(8_u64, 0_u64);
  let length: own u64 = len<u64>(values);
  let cursor: own u64 = 0_u64;
  loop @fill {
    match ieq<u64>(cursor, length) {
      True() => {
        break @fill;
      }
      False() => {
      }
    }
    set index<u64>(values, cursor) = iadd.wrap<u64>(cursor, 1_u64);
    set cursor = iadd.wrap<u64>(cursor, 1_u64);
  }
  set cursor = 0_u64;
  let total: own u64 = 0_u64;
  loop @fold {
    match ieq<u64>(cursor, length) {
      True() => {
        break @fold;
      }
      False() => {
      }
    }
    let value: own u64 = index<u64>(values, cursor);
    set total = iadd.wrap<u64>(total, value);
    set cursor = iadd.wrap<u64>(cursor, 1_u64);
  }
  check ieq<u64>(total, 36_u64) else trap "mutable buffer checksum drift";
  return unit;
}
