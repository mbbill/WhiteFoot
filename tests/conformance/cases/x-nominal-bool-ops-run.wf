fn main() -> own unit traps {
  doc "Exercise every Boolean table operation through normal source compilation and host execution [OP-1, OP-8].";
  let yes: own Bool = True();
  let no: own Bool = False();
  let both: own Bool = band<Bool>(yes, no);
  let not_both: own Bool = bnot<Bool>(both);
  check not_both else trap "band drift";
  let either: own Bool = bor<Bool>(no, yes);
  check either else trap "bor drift";
  let different: own Bool = bxor<Bool>(yes, no);
  check different else trap "bxor off-diagonal drift";
  let same: own Bool = bxor<Bool>(yes, yes);
  let not_same: own Bool = bnot<Bool>(same);
  check not_same else trap "bxor diagonal drift";
  return unit;
}
