struct Pool {
  left: buffer<u64>;
  right: buffer<u64>;
  count: u64;
}

fn build ['r](pool: &uniq 'r Pool, depth: own u32) -> own u64 reads('r), writes('r), traps {
  doc "Build a complete tree bottom-up in two parallel buffers; index zero is the null sentinel.";
  let leaves: own u64 = ishl.wrap<u64>(1_u64, depth);
  let start: own u64 = deref(pool).count;
  let index_value: own u64 = 0_u64;
  loop @leaves {
    let done: own Bool = ige<u64>(index_value, leaves);
    match done {
      True() => {
        break @leaves;
      }
      False() => {
        let slot: own u64 = deref(pool).count;
        set index<u64>(deref(pool).left, slot) = 0_u64;
        set index<u64>(deref(pool).right, slot) = 0_u64;
        set deref(pool).count = iadd.trap<u64>(slot, 1_u64);
        set index_value = iadd.trap<u64>(index_value, 1_u64);
      }
    }
  }
  let width: own u64 = leaves;
  loop @levels {
    let complete: own Bool = ile<u64>(width, 1_u64);
    match complete {
      True() => {
        break @levels;
      }
      False() => {
        let half: own u64 = ishr.wrap<u64>(width, 1_u32);
        let next_start: own u64 = deref(pool).count;
        let parent: own u64 = 0_u64;
        loop @parents {
          let parents_done: own Bool = ige<u64>(parent, half);
          match parents_done {
            True() => {
              break @parents;
            }
            False() => {
              let doubled: own u64 = imul.trap<u64>(parent, 2_u64);
              let left_child: own u64 = iadd.trap<u64>(start, doubled);
              let right_child: own u64 = iadd.trap<u64>(left_child, 1_u64);
              let slot: own u64 = deref(pool).count;
              set index<u64>(deref(pool).left, slot) = left_child;
              set index<u64>(deref(pool).right, slot) = right_child;
              set deref(pool).count = iadd.trap<u64>(slot, 1_u64);
              set parent = iadd.trap<u64>(parent, 1_u64);
            }
          }
        }
        set start = next_start;
        set width = half;
      }
    }
  }
  return start;
}

fn checksum ['r](pool: &'r Pool, root: own u64) -> own u64 reads('r), traps {
  let left_child: own u64 = index<u64>(deref(pool).left, root);
  let leaf: own Bool = ieq<u64>(left_child, 0_u64);
  match leaf {
    True() => {
      return 1_u64;
    }
    False() => {
    }
  }
  let right_child: own u64 = index<u64>(deref(pool).right, root);
  let left_count: own u64 = checksum<'r>(pool: pool, root: left_child);
  let right_count: own u64 = checksum<'r>(pool: pool, root: right_child);
  let children: own u64 = iadd.trap<u64>(left_count, right_count);
  return iadd.trap<u64>(children, 1_u64);
}

fn main() -> own unit allocates(heap), traps {
  let capacity: own u64 = 64_u64;
  let left: own buffer<u64> = buffer_new<u64>(capacity, 0_u64);
  let right: own buffer<u64> = buffer_new<u64>(capacity, 0_u64);
  let pool: own Pool = Pool(left: move left, right: move right, count: 1_u64);
  let depth: own u32 = 5_u32;
  region 'tree {
    let root: own u64 = build<'tree>(pool: &uniq 'tree pool, depth: depth);
    let nodes: own u64 = checksum<'tree>(pool: &'tree pool, root: root);
    check ieq<u64>(nodes, 63_u64) else trap "tree checksum drift";
  }
  let used: own u64 = pool.count;
  check ieq<u64>(used, 64_u64) else trap "tree allocation drift";
  return unit;
}
