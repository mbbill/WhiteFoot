enum State {
  Ready();
  Done();
}

struct Holder {
  state: State;
}

fn main() -> own unit allocates(heap), traps {
  doc "OWN-1: projected Copy reads do not consume their affine struct or buffer owner.";
  let state: own State = Ready();
  let holder: own Holder = Holder(state: state);
  match holder.state {
    Ready() => {
    }
    Done() => {
    }
  }
  match holder.state {
    Ready() => {
    }
    Done() => {
    }
  }
  let saved_holder: own Holder = move holder;
  let items: own buffer<u8> = buffer_new<u8>(2_u64, 7_u8);
  let first: own u8 = index<u8>(items, 0_u64);
  let second: own u8 = index<u8>(items, 1_u64);
  check ieq<u8>(first, 7_u8) else trap "first indexed copy";
  check ieq<u8>(second, 7_u8) else trap "second indexed copy";
  let saved_items: own buffer<u8> = move items;
  return unit;
}
