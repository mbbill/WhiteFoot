const fixed_bytes: array<u8, 3> = [7_u8, 13_u8, 19_u8];

fn fixed_view ['r]() -> own slice<'r, u8> pure {
  let view: own slice<'r, u8> = slice_of<'r, u8>(&'r fixed_bytes);
  return move view;
}

fn main() -> own unit traps {
  region 'view {
    let view: own slice<'view, u8> = fixed_view<'view>();
    let observed: own u8 = index<u8>(view, 1_u64);
    check ieq<u8>(observed, 13_u8) else trap "returned const slice";
  }
  return unit;
}
