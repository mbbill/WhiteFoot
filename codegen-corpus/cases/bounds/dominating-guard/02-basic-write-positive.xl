fn probe (b: own buffer<u8>) -> own unit traps {
  doc "PROOF-1 positive: the same guard licenses a direct element write.";
  let m: own u64 = len<u8>(b);
  let i: own u64 = 0_u64;
  loop @fill {
    match ige<u64>(i, m) {
      True() => {
        break @fill;
      }
      False() => {
      }
    }
    set index<u8>(b, i) = 7_u8;
    set i = iadd.wrap<u64>(i, 1_u64);
  }
  return unit;
}
