const table: array<u8, 4> = [11_u8, 21_u8, 31_u8, 41_u8];

fn lookup (source: own u64) -> own u8 traps {
  let bounded: own u64 = iand<u64>(source, 3_u64);
  doc "A documentation statement does not alter the mask proof.";
  return index<u8>(table, bounded);
}

fn main () -> own unit traps {
  let value: own u8 = lookup(source: 6_u64);
  check ieq<u8>(value, 31_u8) else trap "benign doc drift";
  return unit;
}
