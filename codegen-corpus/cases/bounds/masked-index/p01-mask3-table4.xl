const table: array<u8, 4> = [10_u8, 20_u8, 30_u8, 40_u8];

fn lookup (x: own u64) -> own u8 traps {
  let slot: own u64 = iand<u64>(x, 3_u64);
  return index<u8>(table, slot);
}

fn main () -> own unit traps {
  let value: own u8 = lookup(x: 7_u64);
  check ieq<u8>(value, 40_u8) else trap "masked lookup drift";
  return unit;
}
