const first: array<u8, 8> = [1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8, 8_u8];
const second: array<u8, 8> = [11_u8, 12_u8, 13_u8, 14_u8, 15_u8, 16_u8, 17_u8, 18_u8];

fn lookup (x: own u64) -> own u8 traps {
  let slot: own u64 = iand<u64>(x, 7_u64);
  let a: own u8 = index<u8>(first, slot);
  let b: own u8 = index<u8>(second, slot);
  return iadd.wrap<u8>(a, b);
}

fn main () -> own unit traps {
  let value: own u8 = lookup(x: 10_u64);
  check ieq<u8>(value, 16_u8) else trap "two-read drift";
  return unit;
}
