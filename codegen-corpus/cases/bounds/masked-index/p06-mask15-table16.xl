const table: array<u8, 16> = [0_u8, 1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8, 8_u8, 9_u8, 10_u8, 11_u8, 12_u8, 13_u8, 14_u8, 15_u8];

fn lookup (x: own u64) -> own u8 traps {
  let slot: own u64 = iand<u64>(x, 15_u64);
  return index<u8>(table, slot);
}

fn main () -> own unit traps {
  let value: own u8 = lookup(x: 31_u64);
  check ieq<u8>(value, 15_u8) else trap "mask fifteen drift";
  return unit;
}
