{
  "schema": 1,
  "family": "bounds/masked-index",
  "tags": ["bounds", "proof-1", "masked-index"],
  "hypothesis": "For a const array of power-of-two length N, a direct index temporary defined as iand<u64>(source, N - 1) is in bounds. Facts-on compilation may elide that index check. Changing any structural premise must conservatively retain the check, even when a broader prover could establish safety.",
  "measurement": {
    "function": "lookup",
    "metric": "proof.sites",
    "opt": "O2",
    "facts_on": "compile_program(source, alias=true)",
    "facts_off": "compile_program(source, alias=false)",
    "note": "Count traps only in lookup; main deliberately contains an independent result check."
  },
  "cases": [
    {
      "id": "p01-mask3-table4",
      "source": "p01-mask3-table4.xl",
      "hypothesis": "The minimal N=4 direct mask idiom is proven.",
      "tags": ["positive", "power-of-two", "mask-3", "baseline"],
      "maturity": "gate",
      "expected": {"proof_classification": "elided", "bounds_sites": 1, "facts_trap_calls": 0, "nofacts_trap_calls": 1, "trap_relation": "facts < nofacts"}
    },
    {
      "id": "p02-mask3-benign-doc",
      "source": "p02-mask3-benign-doc.xl",
      "hypothesis": "A doc statement between mask and access does not invalidate the proof.",
      "tags": ["positive", "power-of-two", "metamorphic", "benign-doc"],
      "maturity": "gate",
      "expected": {"proof_classification": "elided", "bounds_sites": 1, "facts_trap_calls": 0, "nofacts_trap_calls": 1, "trap_relation": "facts < nofacts"}
    },
    {
      "id": "p03-mask3-benign-independent-let",
      "source": "p03-mask3-benign-independent-let.xl",
      "hypothesis": "Independent wrapped arithmetic between mask and access does not invalidate the proof.",
      "tags": ["positive", "power-of-two", "metamorphic", "benign-let"],
      "maturity": "gate",
      "expected": {"proof_classification": "elided", "bounds_sites": 1, "facts_trap_calls": 0, "nofacts_trap_calls": 1, "trap_relation": "facts < nofacts"}
    },
    {
      "id": "p04-mask7-table8",
      "source": "p04-mask7-table8.xl",
      "hypothesis": "The direct idiom scales from N=4 to N=8.",
      "tags": ["positive", "power-of-two", "mask-7", "scale"],
