      "tags": ["positive", "power-of-two", "mask-7", "multiple-accesses", "metamorphic"],
      "maturity": "gate",
      "expected": {"proof_classification": "elided", "bounds_sites": 2, "facts_trap_calls": 0, "nofacts_trap_calls": 1, "trap_relation": "facts < nofacts"}
