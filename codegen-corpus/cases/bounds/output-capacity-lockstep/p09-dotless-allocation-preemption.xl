fn probe ['r] (out: &uniq 'r buffer<u8>, src: own buffer<u8>) -> own u64 writes('r), allocates(heap), traps requires {
  let out_len: own u64 = len<u8>(deref(out));
  let src_len: own u64 = len<u8>(src);
  let groups: own u64 = ishr.wrap<u64>(out_len, 2_u32);
  let covered: own u64 = imul.wrap<u64>(groups, 3_u64);
  check ile<u64>(src_len, covered) else trap "output capacity";
} {
  let n: own u64 = len<u8>(src);
  let i: own u64 = 0_u64;
  let o: own u64 = 0_u64;
  loop @groups {
    let rem: own u64 = isub.wrap<u64>(n, i);
    match ilt<u64>(rem, 3_u64) {
      True() => {
        break @groups;
      }
      False() => {
      }
    }
    let scratch_full: own buffer<u64> = buffer_new<u64>(18446744073709551615_u64, 0_u64);
    let o1: own u64 = iadd.wrap<u64>(o, 1_u64);
    let o2: own u64 = iadd.wrap<u64>(o, 2_u64);
    let o3: own u64 = iadd.wrap<u64>(o, 3_u64);
    set index<u8>(deref(out), o) = 0_u8;
    set index<u8>(deref(out), o1) = 1_u8;
    set index<u8>(deref(out), o2) = 2_u8;
    set index<u8>(deref(out), o3) = 3_u8;
    set i = iadd.wrap<u64>(i, 3_u64);
    set o = iadd.wrap<u64>(o, 4_u64);
  }
  let tail: own u64 = isub.wrap<u64>(n, i);
  match ieq<u64>(tail, 1_u64) {
    True() => {
      let scratch_one: own buffer<u64> = buffer_new<u64>(18446744073709551615_u64, 0_u64);
      let a1: own u64 = iadd.wrap<u64>(o, 1_u64);
      let a2: own u64 = iadd.wrap<u64>(o, 2_u64);
      let a3: own u64 = iadd.wrap<u64>(o, 3_u64);
      set index<u8>(deref(out), o) = 4_u8;
      set index<u8>(deref(out), a1) = 5_u8;
      set index<u8>(deref(out), a2) = 6_u8;
      set index<u8>(deref(out), a3) = 7_u8;
      set o = iadd.wrap<u64>(o, 4_u64);
    }
    False() => {
    }
  }
  match ieq<u64>(tail, 2_u64) {
    True() => {
      let scratch_two: own buffer<u64> = buffer_new<u64>(18446744073709551615_u64, 0_u64);
      let b1: own u64 = iadd.wrap<u64>(o, 1_u64);
      let b2: own u64 = iadd.wrap<u64>(o, 2_u64);
      let b3: own u64 = iadd.wrap<u64>(o, 3_u64);
      set index<u8>(deref(out), o) = 8_u8;
      set index<u8>(deref(out), b1) = 9_u8;
      set index<u8>(deref(out), b2) = 10_u8;
      set index<u8>(deref(out), b3) = 11_u8;
      set o = iadd.wrap<u64>(o, 4_u64);
    }
    False() => {
    }
  }
  return o;
}
