const table: array<u8, 8> = [0_u8, 1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8];

fn probe (x: own u32) -> own u8 traps {
  let masked: own u32 = iand<u32>(x, 7_u32);
  let slot: own u64 = cvt<u32, u64>(masked);
  region 'r {
    let p: &uniq 'r u64 = &uniq 'r slot;
    set deref(p) = 8_u64;
  }
  return index<u8>(table, slot);
}
