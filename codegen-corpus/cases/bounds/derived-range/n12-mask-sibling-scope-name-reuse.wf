const table: array<u8, 8> = [0_u8, 1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8];

fn probe (flag: own Bool, x: own u64) -> own u8 traps {
  match flag {
    True() => {
      let slot: own u64 = iand<u64>(x, 7_u64);
      return 0_u8;
    }
    False() => {
      let slot: own u64 = 8_u64;
      return index<u8>(table, slot);
    }
  }
}
