{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlang.local/codegen-corpus/schema.json",
  "title": "xlang codegen corpus family",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "family", "tags", "hypothesis", "measurement", "cases"],
  "properties": {
    "schema": {"const": 1},
    "family": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[/-][a-z0-9]+)*$"
    },
    "tags": {"$ref": "#/$defs/tags"},
    "hypothesis": {"type": "string", "minLength": 1},
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["function", "metric"],
      "properties": {
        "function": {"type": "string", "minLength": 1},
        "metric": {"type": "string", "minLength": 3},
        "opt": {"enum": ["O0", "O1", "O2", "O3", "Os", "Oz"]},
        "facts_on": {"type": "string"},
        "facts_off": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "hypothesis", "tags", "maturity", "expected"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "source": {"type": "string", "pattern": "^[^/]+\\.xl$"},
        "hypothesis": {"type": "string", "minLength": 1},
        "tags": {"$ref": "#/$defs/tags"},
        "maturity": {"enum": ["explore", "audit", "gate"]},
        "expected": {
          "type": "object",
          "required": ["proof_classification"],
          "properties": {
            "proof_classification": {"enum": ["proved", "elided", "retained", "checked"]}
          },
          "additionalProperties": true
        }
      }
    }
  }
}
