fn parser_parse_statement ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let let_word: own Bool = parser_word3(source: source, tokens: tokens, token: cursor, a: 108_u8, b: 101_u8, c: 116_u8);
  match let_word {
    True() => {
      region 'let_parse {
        return parser_parse_let(source: source, tokens: tokens, out: &uniq 'let_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  let return_word: own Bool = parser_word6(source: source, tokens: tokens, token: cursor, a: 114_u8, b: 101_u8, c: 116_u8, d: 117_u8, e: 114_u8, f: 110_u8);
  match return_word {
    True() => {
      region 'return_parse {
        return parser_parse_return(source: source, tokens: tokens, out: &uniq 'return_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  region 'statement_error {
    parser_fail(tokens: tokens, out: &uniq 'statement_error deref(out), status: ParseExpectedStatement(), token: cursor);
  }
  return ParserNodeResult(node: ast_none, next: cursor);
}

