  }
  let return_mode_cursor: own u64 = iadd.trap<u64>(arrow_cursor, 1_u64);
  let parsed_return_mode_node: own u64 = ast_none;
  let parsed_return_mode_next: own u64 = return_mode_cursor;
  region 'return_mode_parse {
    let parsed_return_mode: own ParserNodeResult = parser_parse_own(source: source, tokens: tokens, out: &uniq 'return_mode_parse deref(out), cursor: return_mode_cursor);
    set parsed_return_mode_node = parsed_return_mode.node;
    set parsed_return_mode_next = parsed_return_mode.next;
  }
  match ieq<u64>(parsed_return_mode_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: parsed_return_mode_next);
    }
    False() => {
    }
  }
  region 'return_mode_attach {
    parser_append_child(out: &uniq 'return_mode_attach deref(out), parent: function_node, child: parsed_return_mode_node);
  }
  let parsed_return_type_node: own u64 = ast_none;
  let parsed_return_type_next: own u64 = parsed_return_mode_next;
  region 'return_type_parse {
    let parsed_return_type: own ParserNodeResult = parser_parse_type_node(source: source, tokens: tokens, out: &uniq 'return_type_parse deref(out), cursor: parsed_return_mode_next, kind: AstReturnType());
    set parsed_return_type_node = parsed_return_type.node;
    set parsed_return_type_next = parsed_return_type.next;
  }
  match ieq<u64>(parsed_return_type_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: parsed_return_type_next);
    }
    False() => {
    }
  }
  region 'return_type_attach {
    parser_append_child(out: &uniq 'return_type_attach deref(out), parent: function_node, child: parsed_return_type_node);
  }
  let effect_cursor: own u64 = parsed_return_type_next;
  let effect_ok: own Bool = parser_word4(source: source, tokens: tokens, token: effect_cursor, a: 112_u8, b: 117_u8, c: 114_u8, d: 101_u8);
  match effect_ok {
    True() => {
    }
    False() => {
      region 'function_effect_error {
        parser_fail(tokens: tokens, out: &uniq 'function_effect_error deref(out), status: ParseExpectedPure(), token: effect_cursor);
      }
      return ParserNodeResult(node: ast_none, next: effect_cursor);
    }
  }
  let effect_node: own u64 = ast_none;
  region 'effect_alloc {
    set effect_node = parser_push_token(tokens: tokens, out: &uniq 'effect_alloc deref(out), kind: AstPureEffect(), token: effect_cursor);
  }
  match ieq<u64>(effect_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: effect_cursor);
    }
    False() => {
    }
  }
  region 'effect_attach {
    parser_append_child(out: &uniq 'effect_attach deref(out), parent: function_node, child: effect_node);
  }
  let left_brace_cursor: own u64 = iadd.trap<u64>(effect_cursor, 1_u64);
  let left_brace: own Bool = parser_symbol_is(source: source, tokens: tokens, token: left_brace_cursor, want: 123_u8);
  match left_brace {
    True() => {
    }
    False() => {
      region 'function_left_brace_error {
        parser_fail(tokens: tokens, out: &uniq 'function_left_brace_error deref(out), status: ParseExpectedLeftBrace(), token: left_brace_cursor);
      }
      return ParserNodeResult(node: ast_none, next: left_brace_cursor);
    }
  }
  let block_node: own u64 = ast_none;
  region 'block_alloc {
    set block_node = parser_push_token(tokens: tokens, out: &uniq 'block_alloc deref(out), kind: AstBlock(), token: left_brace_cursor);
  }
  match ieq<u64>(block_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: left_brace_cursor);
    }
    False() => {
    }
  }
  region 'block_attach {
    parser_append_child(out: &uniq 'block_attach deref(out), parent: function_node, child: block_node);
  }
  let statement_cursor: own u64 = iadd.trap<u64>(left_brace_cursor, 1_u64);
  loop @statements {
    let block_done: own Bool = parser_symbol_is(source: source, tokens: tokens, token: statement_cursor, want: 125_u8);
    match block_done {
      True() => {
        let function_end: own u64 = index<u64>(deref(tokens).ends, statement_cursor);
        set index<u64>(deref(out).ends, block_node) = function_end;
        set index<u64>(deref(out).ends, function_node) = function_end;
        let after_function: own u64 = iadd.trap<u64>(statement_cursor, 1_u64);
        return ParserNodeResult(node: function_node, next: after_function);
      }
      False() => {
      }
    }
    let hit_eof: own Bool = parser_kind_at_is(tokens: tokens, token: statement_cursor, want: 0_u64);
    match hit_eof {
      True() => {
        region 'function_right_brace_error {
          parser_fail(tokens: tokens, out: &uniq 'function_right_brace_error deref(out), status: ParseExpectedRightBrace(), token: statement_cursor);
        }
        return ParserNodeResult(node: ast_none, next: statement_cursor);
      }
      False() => {
      }
    }
    let parsed_statement_node: own u64 = ast_none;
    let parsed_statement_next: own u64 = statement_cursor;
    region 'statement_parse {
      let parsed_statement: own ParserNodeResult = parser_parse_statement(source: source, tokens: tokens, out: &uniq 'statement_parse deref(out), cursor: statement_cursor);
      set parsed_statement_node = parsed_statement.node;
      set parsed_statement_next = parsed_statement.next;
    }
    match ieq<u64>(parsed_statement_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: parsed_statement_next);
      }
      False() => {
      }
    }
    region 'statement_attach {
      parser_append_child(out: &uniq 'statement_attach deref(out), parent: block_node, child: parsed_statement_node);
    }
    set statement_cursor = parsed_statement_next;
  }
}

fn parser_run ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape) -> own unit reads('s 't 'a), writes('a), traps {
  set deref(out).count = 0_u64;
  set deref(out).root = ast_none;
  set deref(out).status = ParseClean();
  set deref(out).error_start = 0_u64;
  set deref(out).error_end = 0_u64;

  let lex_status: own LexStatus = deref(tokens).status;
  match lex_status {
    LexClean() => {
    }
    LexUnknownByte() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
    LexInvalidString() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
    LexUnterminatedString() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
    LexInvalidRegionId() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
    LexInvalidLabel() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
    LexComment() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
    LexCapacity() => {
      set deref(out).status = ParseLexError();
      set deref(out).error_start = deref(tokens).error_start;
      set deref(out).error_end = deref(tokens).error_end;
      return unit;
    }
  }

  let token_count: own u64 = deref(tokens).count;
  let nonempty: own Bool = igt<u64>(token_count, 0_u64);
  let kinds_length: own u64 = len<TokenKind>(deref(tokens).kinds);
  let starts_length: own u64 = len<u64>(deref(tokens).starts);
  let ends_length: own u64 = len<u64>(deref(tokens).ends);
  let kinds_ok: own Bool = ige<u64>(kinds_length, token_count);
  let starts_ok: own Bool = ige<u64>(starts_length, token_count);
  let ends_ok: own Bool = ige<u64>(ends_length, token_count);
  let first_pair: own Bool = band<Bool>(nonempty, kinds_ok);
  let second_pair: own Bool = band<Bool>(starts_ok, ends_ok);
  let token_tape_ok: own Bool = band<Bool>(first_pair, second_pair);
  match token_tape_ok {
    True() => {
    }
    False() => {
      set deref(out).status = ParseInvalidTokenTape();
      return unit;
    }
  }

  let source_size: own u64 = len<u8>(deref(source));
  let eof_token: own u64 = isub.wrap<u64>(token_count, 1_u64);
  let validate_cursor: own u64 = 0_u64;
  let previous_end: own u64 = 0_u64;
  loop @validate_tokens {
    match ige<u64>(validate_cursor, token_count) {
      True() => {
        break @validate_tokens;
      }
      False() => {
      }
    }
    let token_start: own u64 = index<u64>(deref(tokens).starts, validate_cursor);
    let token_end: own u64 = index<u64>(deref(tokens).ends, validate_cursor);
    let ordered: own Bool = ile<u64>(token_start, token_end);
    let in_source: own Bool = ile<u64>(token_end, source_size);
    let monotonic: own Bool = ige<u64>(token_start, previous_end);
    let span_pair: own Bool = band<Bool>(ordered, in_source);
    let valid_span: own Bool = band<Bool>(span_pair, monotonic);
    match valid_span {
      True() => {
      }
      False() => {
        set deref(out).status = ParseInvalidTokenTape();
        set deref(out).error_start = token_start;
        set deref(out).error_end = token_end;
        return unit;
      }
    }
    let token_kind: own TokenKind = index<TokenKind>(deref(tokens).kinds, validate_cursor);
    let token_code: own u64 = parser_token_kind_code(kind: token_kind);
    let is_end_token: own Bool = ieq<u64>(token_code, 0_u64);
    let is_final_token: own Bool = ieq<u64>(validate_cursor, eof_token);
    match is_end_token {
      True() => {
        let eof_start_ok: own Bool = ieq<u64>(token_start, source_size);
        let eof_end_ok: own Bool = ieq<u64>(token_end, source_size);
        let eof_span_ok: own Bool = band<Bool>(eof_start_ok, eof_end_ok);
        let eof_ok: own Bool = band<Bool>(is_final_token, eof_span_ok);
        match eof_ok {
          True() => {
          }
          False() => {
            set deref(out).status = ParseInvalidTokenTape();
            set deref(out).error_start = token_start;
            set deref(out).error_end = token_end;
            return unit;
          }
        }
      }
      False() => {
        let nonempty_span: own Bool = ilt<u64>(token_start, token_end);
        let nonfinal: own Bool = bnot<Bool>(is_final_token);
        let ordinary_ok: own Bool = band<Bool>(nonempty_span, nonfinal);
        match ordinary_ok {
          True() => {
          }
          False() => {
            set deref(out).status = ParseInvalidTokenTape();
            set deref(out).error_start = token_start;
            set deref(out).error_end = token_end;
            return unit;
          }
        }
      }
    }
    set previous_end = token_end;
    set validate_cursor = iadd.trap<u64>(validate_cursor, 1_u64);
  }

  let root_node: own u64 = ast_none;
  region 'root_alloc {
    set root_node = parser_push(out: &uniq 'root_alloc deref(out), kind: AstProgram(), head: eof_token, start: 0_u64, end: source_size);
  }
  match ieq<u64>(root_node, ast_none) {
    True() => {
      return unit;
    }
    False() => {
    }
  }
  set deref(out).root = root_node;

  let item_cursor: own u64 = 0_u64;
  let have_function: own Bool = False();
  loop @items {
    let program_done: own Bool = parser_kind_at_is(tokens: tokens, token: item_cursor, want: 0_u64);
    match program_done {
      True() => {
        match have_function {
          True() => {
            return unit;
          }
          False() => {
            region 'empty_program_error {
              parser_fail(tokens: tokens, out: &uniq 'empty_program_error deref(out), status: ParseExpectedFunction(), token: item_cursor);
            }
            return unit;
          }
        }
      }
      False() => {
      }
    }
    let function_start: own Bool = parser_word2(source: source, tokens: tokens, token: item_cursor, a: 102_u8, b: 110_u8);
    match function_start {
      True() => {
      }
      False() => {
        match have_function {
          True() => {
            region 'trailing_item_error {
              parser_fail(tokens: tokens, out: &uniq 'trailing_item_error deref(out), status: ParseTrailingToken(), token: item_cursor);
            }
          }
          False() => {
            region 'first_item_error {
              parser_fail(tokens: tokens, out: &uniq 'first_item_error deref(out), status: ParseExpectedFunction(), token: item_cursor);
            }
          }
        }
        return unit;
      }
    }
    let parsed_function_node: own u64 = ast_none;
    let parsed_function_next: own u64 = item_cursor;
    region 'function_parse {
      let parsed_function: own ParserNodeResult = parser_parse_function(source: source, tokens: tokens, out: &uniq 'function_parse deref(out), cursor: item_cursor);
      set parsed_function_node = parsed_function.node;
      set parsed_function_next = parsed_function.next;
    }
    match ieq<u64>(parsed_function_node, ast_none) {
      True() => {
        return unit;
      }
      False() => {
      }
    }
    region 'function_attach {
      parser_append_child(out: &uniq 'function_attach deref(out), parent: root_node, child: parsed_function_node);
    }
    set have_function = True();
    set item_cursor = parsed_function_next;
  }
}
