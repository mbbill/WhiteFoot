  loop @parameters {
    let parameters_done: own Bool = parser_symbol_is(source: source, tokens: tokens, token: parameter_cursor, want: 41_u8);
    match parameters_done {
      True() => {
        break @parameters;
      }
      False() => {
      }
    }
    let parsed_parameter_node: own u64 = ast_none;
    let parsed_parameter_next: own u64 = parameter_cursor;
    region 'parameter_parse {
      let parsed_parameter: own ParserNodeResult = parser_parse_parameter(source: source, tokens: tokens, out: &uniq 'parameter_parse deref(out), cursor: parameter_cursor);
      set parsed_parameter_node = parsed_parameter.node;
      set parsed_parameter_next = parsed_parameter.next;
    }
    match ieq<u64>(parsed_parameter_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: parsed_parameter_next);
      }
      False() => {
      }
    }
    region 'parameter_attach {
      parser_append_child(out: &uniq 'parameter_attach deref(out), parent: function_node, child: parsed_parameter_node);
    }
    set parameter_cursor = parsed_parameter_next;
    let comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: parameter_cursor, want: 44_u8);
    match comma {
      True() => {
        let after_comma: own u64 = iadd.trap<u64>(parameter_cursor, 1_u64);
        let trailing_comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_comma, want: 41_u8);
        match trailing_comma {
          True() => {
            region 'parameter_trailing_comma_error {
              parser_fail(tokens: tokens, out: &uniq 'parameter_trailing_comma_error deref(out), status: ParseExpectedName(), token: after_comma);
            }
            return ParserNodeResult(node: ast_none, next: after_comma);
