  let parsed_let_expression_node: own u64 = ast_none;
  let parsed_let_expression_next: own u64 = expression_cursor;
  region 'let_expression_parse {
    let parsed_let_expression: own ParserNodeResult = parser_parse_expression(source: source, tokens: tokens, out: &uniq 'let_expression_parse deref(out), cursor: expression_cursor);
    set parsed_let_expression_node = parsed_let_expression.node;
    set parsed_let_expression_next = parsed_let_expression.next;
  }
  match ieq<u64>(parsed_let_expression_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: parsed_let_expression_next);
    }
    False() => {
    }
  }
  region 'let_expression_attach {
    parser_append_child(out: &uniq 'let_expression_attach deref(out), parent: let_node, child: parsed_let_expression_node);
  }
  let semicolon_cursor: own u64 = parsed_let_expression_next;
  let semicolon: own Bool = parser_symbol_is(source: source, tokens: tokens, token: semicolon_cursor, want: 59_u8);
