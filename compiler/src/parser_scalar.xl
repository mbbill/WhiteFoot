struct ParserNodeResult {
  node: u64;
  next: u64;
}

fn parser_append_child ['a] (out: &uniq 'a AstTape, parent: own u64, child: own u64) -> own unit reads('a), writes('a), traps {
  let previous: own u64 = index<u64>(deref(out).last_children, parent);
  let empty: own Bool = ieq<u64>(previous, ast_none);
  match empty {
    True() => {
      set index<u64>(deref(out).first_children, parent) = child;
    }
    False() => {
      set index<u64>(deref(out).next_siblings, previous) = child;
    }
  }
  set index<u64>(deref(out).last_children, parent) = child;
  return unit;
}

fn parser_fail ['t, 'a] (tokens: &'t TokenTape, out: &uniq 'a AstTape, status: own ParseStatus, token: own u64) -> own unit reads('t 'a), writes('a), traps {
  set deref(out).status = status;
  set deref(out).error_start = parser_error_start(tokens: tokens, token: token);
  set deref(out).error_end = parser_error_end(tokens: tokens, token: token);
  return unit;
}

fn parser_simple_type ['s, 't] (source: &'s buffer<u8>, tokens: &'t TokenTape, token: own u64) -> own Bool reads('s 't), traps {
  let i8_type: own Bool = parser_word2(source: source, tokens: tokens, token: token, a: 105_u8, b: 56_u8);
  match i8_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let u8_type: own Bool = parser_word2(source: source, tokens: tokens, token: token, a: 117_u8, b: 56_u8);
  match u8_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let i16_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 105_u8, b: 49_u8, c: 54_u8);
  match i16_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let i32_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 105_u8, b: 51_u8, c: 50_u8);
  match i32_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let i64_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 105_u8, b: 54_u8, c: 52_u8);
  match i64_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let u16_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 117_u8, b: 49_u8, c: 54_u8);
  match u16_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let u32_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 117_u8, b: 51_u8, c: 50_u8);
  match u32_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let u64_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 117_u8, b: 54_u8, c: 52_u8);
  match u64_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let f32_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 102_u8, b: 51_u8, c: 50_u8);
  match f32_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let f64_type: own Bool = parser_word3(source: source, tokens: tokens, token: token, a: 102_u8, b: 54_u8, c: 52_u8);
  match f64_type {
    True() => {
      return True();
    }
    False() => {
    }
  }
  return parser_word4(source: source, tokens: tokens, token: token, a: 117_u8, b: 110_u8, c: 105_u8, d: 116_u8);
}

fn parser_push_token ['t, 'a] (tokens: &'t TokenTape, out: &uniq 'a AstTape, kind: own AstKind, token: own u64) -> own u64 reads('t 'a), writes('a), traps {
  let token_start: own u64 = index<u64>(deref(tokens).starts, token);
  let token_end: own u64 = index<u64>(deref(tokens).ends, token);
  let node: own u64 = ast_none;
  region 'token_alloc {
    set node = parser_push(out: &uniq 'token_alloc deref(out), kind: kind, head: token, start: token_start, end: token_end);
  }
  return node;
}

fn parser_parse_own ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let own_word: own Bool = parser_word3(source: source, tokens: tokens, token: cursor, a: 111_u8, b: 119_u8, c: 110_u8);
  match own_word {
    True() => {
    }
    False() => {
      region 'own_error {
        parser_fail(tokens: tokens, out: &uniq 'own_error deref(out), status: ParseExpectedOwn(), token: cursor);
      }
      return ParserNodeResult(node: ast_none, next: cursor);
    }
  }
  let mode_node: own u64 = ast_none;
  region 'own_alloc {
    set mode_node = parser_push_token(tokens: tokens, out: &uniq 'own_alloc deref(out), kind: AstOwnMode(), token: cursor);
  }
  let next_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  return ParserNodeResult(node: mode_node, next: next_cursor);
}

fn parser_parse_type_node ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64, kind: own AstKind) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let valid_type: own Bool = parser_simple_type(source: source, tokens: tokens, token: cursor);
  match valid_type {
    True() => {
    }
    False() => {
      region 'type_error {
        parser_fail(tokens: tokens, out: &uniq 'type_error deref(out), status: ParseExpectedReturnType(), token: cursor);
      }
      return ParserNodeResult(node: ast_none, next: cursor);
    }
  }
  let type_node: own u64 = ast_none;
  region 'type_alloc {
    set type_node = parser_push_token(tokens: tokens, out: &uniq 'type_alloc deref(out), kind: kind, token: cursor);
  }
  let next_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  return ParserNodeResult(node: type_node, next: next_cursor);
}

fn parser_parse_atom ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let number: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 6_u64);
  match number {
    True() => {
      let number_node: own u64 = ast_none;
      region 'number_alloc {
        set number_node = parser_push_token(tokens: tokens, out: &uniq 'number_alloc deref(out), kind: AstNumericLiteral(), token: cursor);
      }
      let after_number: own u64 = iadd.trap<u64>(cursor, 1_u64);
      return ParserNodeResult(node: number_node, next: after_number);
    }
    False() => {
    }
  }
  let word: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 1_u64);
  match word {
    True() => {
      let unit_word: own Bool = parser_word4(source: source, tokens: tokens, token: cursor, a: 117_u8, b: 110_u8, c: 105_u8, d: 116_u8);
      let atom_kind: own AstKind = AstPlaceUse();
      match unit_word {
        True() => {
          set atom_kind = AstUnitLiteral();
        }
        False() => {
        }
      }
      let word_node: own u64 = ast_none;
      region 'word_alloc {
        set word_node = parser_push_token(tokens: tokens, out: &uniq 'word_alloc deref(out), kind: atom_kind, token: cursor);
      }
      let after_word: own u64 = iadd.trap<u64>(cursor, 1_u64);
      return ParserNodeResult(node: word_node, next: after_word);
    }
    False() => {
    }
  }
  region 'atom_error {
    parser_fail(tokens: tokens, out: &uniq 'atom_error deref(out), status: ParseExpectedAtom(), token: cursor);
  }
  return ParserNodeResult(node: ast_none, next: cursor);
}

fn parser_parse_table_call ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let call_node: own u64 = ast_none;
  region 'table_alloc {
    set call_node = parser_push_token(tokens: tokens, out: &uniq 'table_alloc deref(out), kind: AstTableCall(), token: cursor);
  }
  match ieq<u64>(call_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: cursor);
    }
    False() => {
    }
  }
  let after_callee: own u64 = iadd.trap<u64>(cursor, 1_u64);
  let left_angle: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_callee, want: 60_u8);
  match left_angle {
    True() => {
    }
    False() => {
      region 'left_angle_error {
        parser_fail(tokens: tokens, out: &uniq 'left_angle_error deref(out), status: ParseExpectedLeftAngle(), token: after_callee);
      }
      return ParserNodeResult(node: ast_none, next: after_callee);
    }
  }
  let type_cursor: own u64 = iadd.trap<u64>(after_callee, 1_u64);
  let parsed_type_node: own u64 = ast_none;
  let parsed_type_next: own u64 = type_cursor;
  region 'table_type_parse {
    let parsed_type: own ParserNodeResult = parser_parse_type_node(source: source, tokens: tokens, out: &uniq 'table_type_parse deref(out), cursor: type_cursor, kind: AstTypeArgument());
    set parsed_type_node = parsed_type.node;
    set parsed_type_next = parsed_type.next;
  }
  match ieq<u64>(parsed_type_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: parsed_type_next);
    }
    False() => {
    }
  }
  region 'table_type_attach {
    parser_append_child(out: &uniq 'table_type_attach deref(out), parent: call_node, child: parsed_type_node);
  }
  let right_angle_cursor: own u64 = parsed_type_next;
  let right_angle: own Bool = parser_symbol_is(source: source, tokens: tokens, token: right_angle_cursor, want: 62_u8);
  match right_angle {
    True() => {
    }
    False() => {
      region 'right_angle_error {
        parser_fail(tokens: tokens, out: &uniq 'right_angle_error deref(out), status: ParseExpectedRightAngle(), token: right_angle_cursor);
      }
      return ParserNodeResult(node: ast_none, next: right_angle_cursor);
    }
  }
  let left_paren_cursor: own u64 = iadd.trap<u64>(right_angle_cursor, 1_u64);
  let left_paren: own Bool = parser_symbol_is(source: source, tokens: tokens, token: left_paren_cursor, want: 40_u8);
  match left_paren {
    True() => {
    }
    False() => {
      region 'table_left_paren_error {
        parser_fail(tokens: tokens, out: &uniq 'table_left_paren_error deref(out), status: ParseExpectedLeftParen(), token: left_paren_cursor);
      }
      return ParserNodeResult(node: ast_none, next: left_paren_cursor);
    }
  }
  let argument_cursor: own u64 = iadd.trap<u64>(left_paren_cursor, 1_u64);
  loop @table_arguments {
    let immediate_close: own Bool = parser_symbol_is(source: source, tokens: tokens, token: argument_cursor, want: 41_u8);
    match immediate_close {
      True() => {
        let call_end: own u64 = index<u64>(deref(tokens).ends, argument_cursor);
        set index<u64>(deref(out).ends, call_node) = call_end;
        let after_call: own u64 = iadd.trap<u64>(argument_cursor, 1_u64);
        return ParserNodeResult(node: call_node, next: after_call);
      }
      False() => {
      }
    }
    let parsed_argument_node: own u64 = ast_none;
    let parsed_argument_next: own u64 = argument_cursor;
    region 'table_argument_parse {
      let parsed_argument: own ParserNodeResult = parser_parse_atom(source: source, tokens: tokens, out: &uniq 'table_argument_parse deref(out), cursor: argument_cursor);
      set parsed_argument_node = parsed_argument.node;
      set parsed_argument_next = parsed_argument.next;
    }
    match ieq<u64>(parsed_argument_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: parsed_argument_next);
      }
      False() => {
      }
    }
    region 'table_argument_attach {
      parser_append_child(out: &uniq 'table_argument_attach deref(out), parent: call_node, child: parsed_argument_node);
    }
    set argument_cursor = parsed_argument_next;
    let comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: argument_cursor, want: 44_u8);
    match comma {
      True() => {
        let after_comma: own u64 = iadd.trap<u64>(argument_cursor, 1_u64);
        let trailing_comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_comma, want: 41_u8);
        match trailing_comma {
          True() => {
            region 'table_trailing_comma_error {
              parser_fail(tokens: tokens, out: &uniq 'table_trailing_comma_error deref(out), status: ParseExpectedAtom(), token: after_comma);
            }
            return ParserNodeResult(node: ast_none, next: after_comma);
          }
          False() => {
          }
        }
        set argument_cursor = after_comma;
      }
      False() => {
        let closing: own Bool = parser_symbol_is(source: source, tokens: tokens, token: argument_cursor, want: 41_u8);
        match closing {
          True() => {
          }
          False() => {
            region 'table_separator_error {
              parser_fail(tokens: tokens, out: &uniq 'table_separator_error deref(out), status: ParseExpectedCommaOrRightParen(), token: argument_cursor);
            }
            return ParserNodeResult(node: ast_none, next: argument_cursor);
          }
        }
      }
    }
  }
}

fn parser_parse_user_call ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let call_node: own u64 = ast_none;
  region 'user_alloc {
    set call_node = parser_push_token(tokens: tokens, out: &uniq 'user_alloc deref(out), kind: AstUserCall(), token: cursor);
  }
  match ieq<u64>(call_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: cursor);
    }
    False() => {
    }
  }
  let left_paren_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  let left_paren: own Bool = parser_symbol_is(source: source, tokens: tokens, token: left_paren_cursor, want: 40_u8);
  match left_paren {
    True() => {
    }
    False() => {
      region 'user_left_paren_error {
        parser_fail(tokens: tokens, out: &uniq 'user_left_paren_error deref(out), status: ParseExpectedLeftParen(), token: left_paren_cursor);
      }
      return ParserNodeResult(node: ast_none, next: left_paren_cursor);
    }
  }
  let argument_cursor: own u64 = iadd.trap<u64>(left_paren_cursor, 1_u64);
  loop @user_arguments {
    let immediate_close: own Bool = parser_symbol_is(source: source, tokens: tokens, token: argument_cursor, want: 41_u8);
    match immediate_close {
      True() => {
        let call_end: own u64 = index<u64>(deref(tokens).ends, argument_cursor);
        set index<u64>(deref(out).ends, call_node) = call_end;
        let after_call: own u64 = iadd.trap<u64>(argument_cursor, 1_u64);
        return ParserNodeResult(node: call_node, next: after_call);
      }
      False() => {
      }
    }
    let label_ok: own Bool = parser_kind_at_is(tokens: tokens, token: argument_cursor, want: 1_u64);
    match label_ok {
      True() => {
      }
      False() => {
        region 'argument_name_error {
          parser_fail(tokens: tokens, out: &uniq 'argument_name_error deref(out), status: ParseExpectedName(), token: argument_cursor);
        }
        return ParserNodeResult(node: ast_none, next: argument_cursor);
      }
    }
    let named_node: own u64 = ast_none;
    region 'named_alloc {
      set named_node = parser_push_token(tokens: tokens, out: &uniq 'named_alloc deref(out), kind: AstNamedArgument(), token: argument_cursor);
    }
    match ieq<u64>(named_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: argument_cursor);
      }
      False() => {
      }
    }
    let colon_cursor: own u64 = iadd.trap<u64>(argument_cursor, 1_u64);
    let colon: own Bool = parser_symbol_is(source: source, tokens: tokens, token: colon_cursor, want: 58_u8);
    match colon {
      True() => {
      }
      False() => {
        region 'argument_colon_error {
          parser_fail(tokens: tokens, out: &uniq 'argument_colon_error deref(out), status: ParseExpectedColon(), token: colon_cursor);
        }
        return ParserNodeResult(node: ast_none, next: colon_cursor);
      }
    }
    let atom_cursor: own u64 = iadd.trap<u64>(colon_cursor, 1_u64);
    let parsed_atom_node: own u64 = ast_none;
    let parsed_atom_next: own u64 = atom_cursor;
    region 'named_atom_parse {
      let parsed_atom: own ParserNodeResult = parser_parse_atom(source: source, tokens: tokens, out: &uniq 'named_atom_parse deref(out), cursor: atom_cursor);
      set parsed_atom_node = parsed_atom.node;
      set parsed_atom_next = parsed_atom.next;
    }
    match ieq<u64>(parsed_atom_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: parsed_atom_next);
      }
      False() => {
      }
    }
    region 'named_atom_attach {
      parser_append_child(out: &uniq 'named_atom_attach deref(out), parent: named_node, child: parsed_atom_node);
    }
    let named_end: own u64 = index<u64>(deref(out).ends, parsed_atom_node);
    set index<u64>(deref(out).ends, named_node) = named_end;
    region 'named_argument_attach {
      parser_append_child(out: &uniq 'named_argument_attach deref(out), parent: call_node, child: named_node);
    }
    set argument_cursor = parsed_atom_next;
    let comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: argument_cursor, want: 44_u8);
    match comma {
      True() => {
        let after_comma: own u64 = iadd.trap<u64>(argument_cursor, 1_u64);
        let trailing_comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_comma, want: 41_u8);
        match trailing_comma {
          True() => {
            region 'user_trailing_comma_error {
              parser_fail(tokens: tokens, out: &uniq 'user_trailing_comma_error deref(out), status: ParseExpectedName(), token: after_comma);
            }
            return ParserNodeResult(node: ast_none, next: after_comma);
          }
          False() => {
          }
        }
        set argument_cursor = after_comma;
      }
      False() => {
        let closing: own Bool = parser_symbol_is(source: source, tokens: tokens, token: argument_cursor, want: 41_u8);
        match closing {
          True() => {
          }
          False() => {
            region 'user_separator_error {
              parser_fail(tokens: tokens, out: &uniq 'user_separator_error deref(out), status: ParseExpectedCommaOrRightParen(), token: argument_cursor);
            }
            return ParserNodeResult(node: ast_none, next: argument_cursor);
          }
        }
      }
    }
  }
}

fn parser_parse_expression ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let table_callee: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 2_u64);
  match table_callee {
    True() => {
      region 'table_parse {
        return parser_parse_table_call(source: source, tokens: tokens, out: &uniq 'table_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  let word_callee: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 1_u64);
  match word_callee {
    True() => {
      let after_word: own u64 = iadd.trap<u64>(cursor, 1_u64);
      let call_shape: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_word, want: 40_u8);
      match call_shape {
        True() => {
          region 'user_parse {
            return parser_parse_user_call(source: source, tokens: tokens, out: &uniq 'user_parse deref(out), cursor: cursor);
          }
        }
        False() => {
        }
      }
    }
    False() => {
    }
  }
  let number_start: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 6_u64);
  let atom_start: own Bool = bor<Bool>(word_callee, number_start);
  match atom_start {
    True() => {
      region 'expression_atom_parse {
        return parser_parse_atom(source: source, tokens: tokens, out: &uniq 'expression_atom_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  region 'expression_error {
    parser_fail(tokens: tokens, out: &uniq 'expression_error deref(out), status: ParseExpectedExpression(), token: cursor);
  }
  return ParserNodeResult(node: ast_none, next: cursor);
}

fn parser_parse_return ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let return_node: own u64 = ast_none;
  region 'return_alloc {
    set return_node = parser_push_token(tokens: tokens, out: &uniq 'return_alloc deref(out), kind: AstReturn(), token: cursor);
  }
  match ieq<u64>(return_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: cursor);
    }
    False() => {
    }
  }
  let expression_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  let parsed_expression_node: own u64 = ast_none;
  let parsed_expression_next: own u64 = expression_cursor;
  region 'return_expression_parse {
    let parsed_expression: own ParserNodeResult = parser_parse_expression(source: source, tokens: tokens, out: &uniq 'return_expression_parse deref(out), cursor: expression_cursor);
    set parsed_expression_node = parsed_expression.node;
    set parsed_expression_next = parsed_expression.next;
  }
  match ieq<u64>(parsed_expression_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: parsed_expression_next);
    }
    False() => {
    }
  }
  region 'return_expression_attach {
    parser_append_child(out: &uniq 'return_expression_attach deref(out), parent: return_node, child: parsed_expression_node);
  }
  let semicolon_cursor: own u64 = parsed_expression_next;
  let semicolon: own Bool = parser_symbol_is(source: source, tokens: tokens, token: semicolon_cursor, want: 59_u8);
  match semicolon {
    True() => {
    }
    False() => {
      region 'return_semicolon_error {
        parser_fail(tokens: tokens, out: &uniq 'return_semicolon_error deref(out), status: ParseExpectedSemicolon(), token: semicolon_cursor);
      }
      return ParserNodeResult(node: ast_none, next: semicolon_cursor);
    }
  }
  let return_end: own u64 = index<u64>(deref(tokens).ends, semicolon_cursor);
  set index<u64>(deref(out).ends, return_node) = return_end;
  let after_return: own u64 = iadd.trap<u64>(semicolon_cursor, 1_u64);
  return ParserNodeResult(node: return_node, next: after_return);
}

fn parser_parse_let ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
