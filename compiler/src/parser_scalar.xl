  }
  let arrow_cursor: own u64 = iadd.trap<u64>(parameter_cursor, 1_u64);
  let arrow: own Bool = parser_kind_at_is(tokens: tokens, token: arrow_cursor, want: 8_u64);
  match arrow {
    True() => {
    }
    False() => {
      region 'function_arrow_error {
