  }
  let parsed_binding_type_node: own u64 = ast_none;
  let parsed_binding_type_next: own u64 = parsed_mode_next;
  region 'let_type_parse {
    let parsed_binding_type: own ParserNodeResult = parser_parse_type_node(source: source, tokens: tokens, out: &uniq 'let_type_parse deref(out), cursor: parsed_mode_next, kind: AstBindingType());
    set parsed_binding_type_node = parsed_binding_type.node;
    set parsed_binding_type_next = parsed_binding_type.next;
  }
  match ieq<u64>(parsed_binding_type_node, ast_none) {
