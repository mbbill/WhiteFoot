      return False();
    }
  }
  return semantic_buffer_return_valid(source: source, tokens: tokens, ast: ast, node: final_return, left_name: first_name, right_name: e2_name);
}

fn semantic_buffer_write_parameter_facts ['a, 'w] (ast: &'a AstTape, facts: &uniq 'w NodeFacts, parameter: own u64, type_id: own u64, ordinal: own u64, mode: own SemanticValueMode) -> own unit reads('a), writes('w), traps {
  let mode_node: own u64 = semantic_body_child_at(ast: ast, node: parameter, ordinal: 0_u64);
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: parameter, ordinal: 1_u64);
  set index<u64>(deref(facts).type_ids, parameter) = type_id;
  set index<u64>(deref(facts).ordinals, parameter) = ordinal;
  set index<SemanticValueMode>(deref(facts).modes, parameter) = mode;
  set index<u64>(deref(facts).type_ids, mode_node) = type_id;
  set index<SemanticValueMode>(deref(facts).modes, mode_node) = mode;
  set index<u64>(deref(facts).type_ids, type_node) = type_id;
  match ieq<u64>(type_id, semantic_buffer_type_u8_buffer) {
    True() => {
      let element: own u64 = semantic_body_child_at(ast: ast, node: type_node, ordinal: 0_u64);
      set index<u64>(deref(facts).type_ids, element) = semantic_buffer_type_u8;
    }
    False() => {
    }
  }
  return unit;
}

fn semantic_buffer_write_let_facts ['a, 'w] (ast: &'a AstTape, facts: &uniq 'w NodeFacts, declaration: own u64, type_id: own u64, ordinal: own u64) -> own unit reads('a), writes('w), traps {
  let name: own u64 = semantic_body_child_at(ast: ast, node: declaration, ordinal: 0_u64);
  let mode: own u64 = semantic_body_child_at(ast: ast, node: declaration, ordinal: 1_u64);
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: declaration, ordinal: 2_u64);
  set index<u64>(deref(facts).type_ids, declaration) = type_id;
  set index<u64>(deref(facts).ordinals, declaration) = ordinal;
  set index<SemanticValueMode>(deref(facts).modes, declaration) = SemanticModeOwn();
  set index<u64>(deref(facts).type_ids, name) = type_id;
  set index<u64>(deref(facts).type_ids, mode) = type_id;
  set index<SemanticValueMode>(deref(facts).modes, mode) = SemanticModeOwn();
  set index<u64>(deref(facts).type_ids, type_node) = type_id;
  return unit;
}

fn semantic_buffer_write_result_fact ['w] (facts: &uniq 'w NodeFacts, node: own u64, type_id: own u64, ordinal: own u64, operation: own SemanticOperation) -> own unit writes('w), traps {
  set index<u64>(deref(facts).type_ids, node) = type_id;
  set index<u64>(deref(facts).ordinals, node) = ordinal;
  set index<SemanticOperation>(deref(facts).operations, node) = operation;
  set index<SemanticValueMode>(deref(facts).modes, node) = SemanticModeOwn();
  return unit;
