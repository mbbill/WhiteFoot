  }
  set index<u64>(deref(facts).type_ids, literal) = semantic_buffer_type_u64;
  set index<u64>(deref(facts).constant_values, literal) = literal_value;
  set index<SemanticValueMode>(deref(facts).modes, literal) = SemanticModeOwn();
  return unit;
}

fn semantic_buffer_write_index_facts ['a, 'w] (ast: &'a AstTape, facts: &uniq 'w NodeFacts, index_node: own u64, ordinal: own u64, source_declaration: own u64, subscript_declaration: own u64) -> own unit reads('a), writes('w), traps {
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: index_node, ordinal: 0_u64);
