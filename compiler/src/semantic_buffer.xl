fn semantic_buffer_match3_run ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64, validation: &'c AstValidationReport, symbols: &'c SymbolTape, types: &uniq 'w TypeTape, facts: &uniq 'w NodeFacts, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own unit reads('c 'w), writes('w), traps {
  set deref(types).status = SemanticFactsInvalidShape();
  set deref(types).node = semantic_facts_none;
  set deref(types).related = semantic_facts_none;
  set deref(facts).status = SemanticFactsInvalidShape();
  set deref(facts).node = semantic_facts_none;
  set deref(facts).related = semantic_facts_none;
  set deref(report).status = SemanticBodyInvalidTokenTape();
  set deref(report).node = ast_none;
  set deref(report).related = semantic_facts_none;

  let tokens_valid: own Bool = symbol_token_tape_shape_valid(tokens: tokens);
  match tokens_valid {
    True() => {
    }
    False() => {
      set deref(report).related = deref(tokens).count;
      return unit;
    }
  }
  let ast_valid: own Bool = semantic_body_ast_columns_valid(tokens: tokens, ast: ast);
  match ast_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidAstTape();
      set deref(report).node = function;
      set deref(report).related = deref(ast).count;
      return unit;
    }
  }
  let validation_clean: own Bool = ieq<AstValidationStatus>(deref(validation).status, AstValidationClean());
  match validation_clean {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidValidation();
      set deref(report).node = deref(validation).node;
      set deref(report).related = deref(validation).related;
      return unit;
    }
  }
  let symbols_valid: own Bool = symbol_lookup_entries_valid(source: source, tokens: tokens, symbols: symbols);
  match symbols_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidSymbolTape();
      set deref(report).node = function;
      set deref(report).related = deref(symbols).count;
      return unit;
    }
  }
  let ast_count: own u64 = deref(ast).count;
  match ilt<u64>(function, ast_count) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidFunction();
      set deref(report).node = function;
      set deref(report).related = ast_count;
      return unit;
    }
  }

  let types_shape: own Bool = False();
  region 'semantic_buffer_types_shape {
    set types_shape = semantic_type_tape_shape_valid(types: &'semantic_buffer_types_shape deref(types));
  }
  let types_empty: own Bool = ieq<u64>(deref(types).count, 0_u64);
  let types_ready: own Bool = band<Bool>(types_shape, types_empty);
