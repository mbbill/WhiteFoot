      set deref(report).node = function;
      set deref(report).related = deref(types).count;
      return unit;
    }
  }
  let facts_shape: own Bool = False();
  region 'semantic_buffer_facts_shape {
    set facts_shape = semantic_node_facts_shape_valid(facts: &'semantic_buffer_facts_shape deref(facts));
  }
  let facts_empty: own Bool = ieq<u64>(deref(facts).count, 0_u64);
  let facts_ready: own Bool = band<Bool>(facts_shape, facts_empty);
  match facts_ready {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidNodeFacts();
      set deref(report).node = function;
      set deref(report).related = deref(facts).count;
      return unit;
    }
  }
  let scratch_valid: own Bool = False();
  region 'semantic_buffer_scratch_shape {
    set scratch_valid = semantic_body_scratch_shape_valid(scratch: &'semantic_buffer_scratch_shape deref(scratch));
  }
  match scratch_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidScratch();
      set deref(report).node = function;
      set deref(report).related = deref(scratch).count;
      return unit;
    }
  }

  let signature_valid: own Bool = semantic_buffer_match3_signature_valid(source: source, tokens: tokens, ast: ast, function: function);
  match signature_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidFunction();
      set deref(report).node = function;
      set deref(report).related = 12_u64;
      return unit;
    }
  }
  let body_valid: own Bool = semantic_buffer_match3_body_valid(source: source, tokens: tokens, ast: ast, function: function);
