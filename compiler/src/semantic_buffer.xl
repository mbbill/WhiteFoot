  let subscript: own u64 = semantic_body_child_at(ast: ast, node: index_node, ordinal: 2_u64);
  let source_place: own u64 = semantic_body_child_at(ast: ast, node: deref_node, ordinal: 0_u64);
  region 'semantic_buffer_index_result {
    semantic_buffer_write_result_fact(facts: &uniq 'semantic_buffer_index_result deref(facts), node: index_node, type_id: semantic_buffer_type_u8, ordinal: ordinal, operation: SemanticOperationNone());
  }
  set index<u64>(deref(facts).type_ids, type_node) = semantic_buffer_type_u8;
  set index<u64>(deref(facts).type_ids, deref_node) = semantic_buffer_type_u8_buffer;
  set index<SemanticValueMode>(deref(facts).modes, deref_node) = SemanticModeShared();
  region 'semantic_buffer_index_source {
    semantic_buffer_write_place_fact(facts: &uniq 'semantic_buffer_index_source deref(facts), node: source_place, type_id: semantic_buffer_type_u8_buffer, declaration: source_declaration, mode: SemanticModeShared());
  }
  region 'semantic_buffer_index_subscript {
    semantic_buffer_write_place_fact(facts: &uniq 'semantic_buffer_index_subscript deref(facts), node: subscript, type_id: semantic_buffer_type_u64, declaration: subscript_declaration, mode: SemanticModeOwn());
  }
  return unit;
}

fn semantic_buffer_write_binary_facts ['a, 'w] (ast: &'a AstTape, facts: &uniq 'w NodeFacts, call: own u64, ordinal: own u64, operand_type: own u64, operation: own SemanticOperation, left_declaration: own u64, right_declaration: own u64) -> own unit reads('a), writes('w), traps {
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: call, ordinal: 0_u64);
