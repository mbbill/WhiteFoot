fn semantic_buffer_write_iadd_facts ['a, 'w] (ast: &'a AstTape, facts: &uniq 'w NodeFacts, call: own u64, ordinal: own u64, left_declaration: own u64, literal_value: own u64) -> own unit reads('a), writes('w), traps {
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: call, ordinal: 0_u64);
  let left: own u64 = semantic_body_child_at(ast: ast, node: call, ordinal: 1_u64);
