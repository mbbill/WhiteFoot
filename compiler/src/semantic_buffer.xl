  let p1_name: own u64 = semantic_body_child_at(ast: ast, node: p1_let, ordinal: 0_u64);
  let p2_name: own u64 = semantic_body_child_at(ast: ast, node: p2_let, ordinal: 0_u64);
  let b0_name: own u64 = semantic_body_child_at(ast: ast, node: b0_let, ordinal: 0_u64);
  let b1_name: own u64 = semantic_body_child_at(ast: ast, node: b1_let, ordinal: 0_u64);
  let b2_name: own u64 = semantic_body_child_at(ast: ast, node: b2_let, ordinal: 0_u64);
  let e0_name: own u64 = semantic_body_child_at(ast: ast, node: e0_let, ordinal: 0_u64);
  let e1_name: own u64 = semantic_body_child_at(ast: ast, node: e1_let, ordinal: 0_u64);
  let e2_name: own u64 = semantic_body_child_at(ast: ast, node: e2_let, ordinal: 0_u64);
  let first_name: own u64 = semantic_body_child_at(ast: ast, node: first_let, ordinal: 0_u64);
  let p1_value: own u64 = semantic_body_child_at(ast: ast, node: p1_let, ordinal: 3_u64);
  let p2_value: own u64 = semantic_body_child_at(ast: ast, node: p2_let, ordinal: 3_u64);
  let b0_value: own u64 = semantic_body_child_at(ast: ast, node: b0_let, ordinal: 3_u64);
