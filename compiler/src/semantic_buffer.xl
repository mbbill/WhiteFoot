fn semantic_buffer_write_place_fact ['w] (facts: &uniq 'w NodeFacts, node: own u64, type_id: own u64, declaration: own u64, mode: own SemanticValueMode) -> own unit writes('w), traps {
  set index<u64>(deref(facts).type_ids, node) = type_id;
  set index<u64>(deref(facts).resolved_declarations, node) = declaration;
  set index<SemanticValueMode>(deref(facts).modes, node) = mode;
  return unit;
