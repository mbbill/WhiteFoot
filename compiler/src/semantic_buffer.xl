  region 'semantic_buffer_binary_left {
    semantic_buffer_write_place_fact(facts: &uniq 'semantic_buffer_binary_left deref(facts), node: left, type_id: operand_type, declaration: left_declaration, mode: SemanticModeOwn());
  }
  region 'semantic_buffer_binary_right {
    semantic_buffer_write_place_fact(facts: &uniq 'semantic_buffer_binary_right deref(facts), node: right, type_id: operand_type, declaration: right_declaration, mode: SemanticModeOwn());
  }
  return unit;
}

fn semantic_buffer_write_scratch_row ['a, 'w] (ast: &'a AstTape, scratch: &uniq 'w SemanticBodyScratch, slot: own u64, name_node: own u64, declaration: own u64, type_id: own u64, mode: own SemanticValueMode) -> own unit reads('a), writes('w), traps {
