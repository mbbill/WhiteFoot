fn semantic_reader_reborrow_region_leaf_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let ast_region_atom: own AstKind = AstRegion();
  let kind_ok: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_region_atom);
  let token_ok: own Bool = semantic_reader_writer_leaf_token_exact(source: source, tokens: tokens, ast: ast, node: node);
  match band<Bool>(kind_ok, token_ok) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  return parser_kind_at_is(tokens: tokens, token: head, want: 4_u64);
}

fn semantic_reader_reborrow_struct_field_type ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, struct_decl: own u64, field_name_head: own u64) -> own u64 reads('c), traps {
  let existing: own u64 = semantic_reader_struct_field_type(source: source, tokens: tokens, ast: ast, symbols: symbols, struct_decl: struct_decl, field_name_head: field_name_head);
  match ine<u64>(existing, semantic_facts_none) {
    True() => {
      return existing;
    }
    False() => {
    }
  }
  let ast_count: own u64 = deref(ast).count;
  let first: own u64 = index<u64>(deref(ast).first_children, struct_decl);
  let last: own u64 = index<u64>(deref(ast).last_children, struct_decl);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  match bor<Bool>(first_none, last_none) {
    True() => {
      return semantic_facts_none;
    }
    False() => {
    }
  }
  let ast_field_atom: own AstKind = AstField();
  let ast_field_type_atom: own AstKind = AstFieldType();
  let child: own u64 = first;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_reborrow_field_scan {
    match ilt<u64>(child, ast_count) {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
    let child_kind: own AstKind = index<AstKind>(deref(ast).kinds, child);
    let is_field: own Bool = eeq<AstKind>(child_kind, ast_field_atom);
    match is_field {
      True() => {
        let field_shape: own Bool = semantic_body_exact_children(ast: ast, node: child, want: 1_u64);
        let field_source: own Bool = semantic_reader_writer_head_starts_node(source: source, tokens: tokens, ast: ast, node: child);
        match band<Bool>(field_shape, field_source) {
          True() => {
          }
          False() => {
            return semantic_facts_none;
          }
        }
        let field_head: own u64 = index<u64>(deref(ast).heads, child);
        let name_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: field_head, right: field_name_head);
        match name_matches {
          True() => {
            let field_type: own u64 = semantic_body_child_at(ast: ast, node: child, ordinal: 0_u64);
            let field_type_kind: own Bool = semantic_body_kind_is(ast: ast, node: field_type, want: ast_field_type_atom);
            let field_type_token: own Bool = semantic_reader_writer_leaf_token_exact(source: source, tokens: tokens, ast: ast, node: field_type);
            match band<Bool>(field_type_kind, field_type_token) {
              True() => {
                return semantic_reader_named_struct_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, type_node: field_type, type_kind: ast_field_type_atom);
              }
              False() => {
                return semantic_facts_none;
              }
            }
          }
          False() => {
          }
        }
      }
      False() => {
      }
    }
    match ieq<u64>(child, last) {
      True() => {
        return semantic_facts_none;
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match ilt<u64>(next, ast_count) {
      True() => {
        set child = next;
      }
      False() => {
        return semantic_facts_none;
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
  }
}

