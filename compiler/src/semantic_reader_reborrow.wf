  let writes_region_valid: own Bool = semantic_reader_reborrow_region_leaf_valid(source: source, tokens: tokens, ast: ast, node: writes_region);
  let writes_region_head: own u64 = index<u64>(deref(ast).heads, writes_region);
  let writes_region_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: writes_region_head, right: formal_region_head);
  match band<Bool>(writes_region_valid, writes_region_matches) {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let ast_block_atom: own AstKind = AstBlock();
  let body_kind: own Bool = semantic_body_kind_is(ast: ast, node: body, want: ast_block_atom);
  let body_token: own Bool = semantic_buffer_single_symbol_node(source: source, tokens: tokens, ast: ast, node: body, want: 123_u8);
  let body_start: own Bool = semantic_reader_writer_head_starts_node(source: source, tokens: tokens, ast: ast, node: body);
  let body_first: own Bool = band<Bool>(body_kind, body_token);
  let body_shape: own Bool = band<Bool>(body_first, body_start);
  match body_shape {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let no_user_call: own Bool = False();
  let no_index_target: own Bool = False();
  return semantic_reader_writer_body_valid(source: source, tokens: tokens, ast: ast, symbols: symbols, function: callee, writes_node: writes_effect, block: body, allow_user_call: no_user_call, allow_index_target: no_index_target);
}

fn semantic_reader_reborrow_parent_field_type ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, scratch: &'w SemanticBodyScratch, region_block: own u64) -> own u64 reads('c 'w), traps {
  let inner_block: own u64 = semantic_body_child_at(ast: ast, node: region_block, ordinal: 1_u64);
  let expression_statement: own u64 = semantic_body_child_at(ast: ast, node: inner_block, ordinal: 0_u64);
  let call: own u64 = semantic_body_child_at(ast: ast, node: expression_statement, ordinal: 0_u64);
  let named_argument: own u64 = semantic_body_child_at(ast: ast, node: call, ordinal: 0_u64);
  let child_borrow: own u64 = semantic_body_child_at(ast: ast, node: named_argument, ordinal: 0_u64);
  let child_place: own u64 = semantic_body_child_at(ast: ast, node: child_borrow, ordinal: 1_u64);
  let deref_place: own u64 = semantic_body_child_at(ast: ast, node: child_place, ordinal: 0_u64);
  let parent_place: own u64 = semantic_body_child_at(ast: ast, node: deref_place, ordinal: 0_u64);
  let slot: own u64 = semantic_reader_place_slot(source: source, tokens: tokens, ast: ast, scratch: scratch, node: parent_place);
  match ieq<u64>(slot, semantic_facts_none) {
    True() => {
      return semantic_facts_none;
    }
    False() => {
    }
  }
  let parent_mode: own SemanticValueMode = index<SemanticValueMode>(deref(scratch).modes, slot);
  let uniq_mode_atom: own SemanticValueMode = SemanticModeUniq();
  let parent_uniq: own Bool = eeq<SemanticValueMode>(parent_mode, uniq_mode_atom);
  let declaration: own u64 = index<u64>(deref(scratch).declarations, slot);
  let ast_parameter_atom: own AstKind = AstParameter();
  let declaration_kind: own Bool = semantic_body_kind_is(ast: ast, node: declaration, want: ast_parameter_atom);
  let declaration_shape: own Bool = semantic_body_exact_children(ast: ast, node: declaration, want: 2_u64);
  let declaration_start: own Bool = semantic_reader_writer_head_starts_node(source: source, tokens: tokens, ast: ast, node: declaration);
  let declaration_first: own Bool = band<Bool>(declaration_kind, declaration_shape);
  let declaration_second: own Bool = band<Bool>(parent_uniq, declaration_start);
  match band<Bool>(declaration_first, declaration_second) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let declaration_mode: own u64 = semantic_body_child_at(ast: ast, node: declaration, ordinal: 0_u64);
  let ast_uniq_mode_atom: own AstKind = AstUniqMode();
  let declaration_mode_kind: own Bool = semantic_body_kind_is(ast: ast, node: declaration_mode, want: ast_uniq_mode_atom);
  let declaration_mode_valid: own Bool = semantic_function_mode_valid(source: source, tokens: tokens, ast: ast, node: declaration_mode);
  match band<Bool>(declaration_mode_kind, declaration_mode_valid) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let parent_type: own u64 = index<u64>(deref(scratch).type_ids, slot);
  let parent_struct: own Bool = ige<u64>(parent_type, semantic_reader_struct_type_base);
  match parent_struct {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let parent_struct_decl: own u64 = isub.wrap<u64>(parent_type, semantic_reader_struct_type_base);
  let field_head: own u64 = index<u64>(deref(ast).heads, child_place);
  return semantic_reader_reborrow_struct_field_type(source: source, tokens: tokens, ast: ast, symbols: symbols, struct_decl: parent_struct_decl, field_name_head: field_head);
}

fn semantic_reader_analyze_reborrow_region ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, regions_node: own u64, statement: own u64, scratch: &'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own Bool reads('c 'w), writes('w), traps {
  let shape_valid: own Bool = semantic_reader_reborrow_region_shape_valid(source: source, tokens: tokens, ast: ast, node: statement);
  match shape_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = statement;
      return False();
    }
  }
  let local_region: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 0_u64);
  let inner_block: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 1_u64);
  let expression_statement: own u64 = semantic_body_child_at(ast: ast, node: inner_block, ordinal: 0_u64);
  let call: own u64 = semantic_body_child_at(ast: ast, node: expression_statement, ordinal: 0_u64);
  let named_argument: own u64 = semantic_body_child_at(ast: ast, node: call, ordinal: 0_u64);
  let child_borrow: own u64 = semantic_body_child_at(ast: ast, node: named_argument, ordinal: 0_u64);
  let child_region: own u64 = semantic_body_child_at(ast: ast, node: child_borrow, ordinal: 0_u64);
  let local_region_head: own u64 = index<u64>(deref(ast).heads, local_region);
  let child_region_head: own u64 = index<u64>(deref(ast).heads, child_region);
  let region_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: local_region_head, right: child_region_head);
  let shadows_parameter: own Bool = semantic_reader_region_declared(source: source, tokens: tokens, ast: ast, regions_node: regions_node, head_token: local_region_head);
  let local_fresh: own Bool = bnot<Bool>(shadows_parameter);
  match band<Bool>(region_matches, local_fresh) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = child_region;
      return False();
    }
  }
  let field_type: own u64 = semantic_reader_reborrow_parent_field_type(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: scratch, region_block: statement);
  match ieq<u64>(field_type, semantic_facts_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = child_borrow;
      return False();
    }
    False() => {
    }
  }
  let callee_valid: own Bool = semantic_reader_reborrow_callee_valid(source: source, tokens: tokens, ast: ast, symbols: symbols, call: call, named_argument: named_argument, expected_type: field_type);
  match callee_valid {
    True() => {
      return True();
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = call;
      return False();
    }
  }
}
