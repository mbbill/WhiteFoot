fn semantic_reader_reborrow_return_unit_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let ast_return_atom: own AstKind = AstReturn();
  let return_kind: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_return_atom);
  let return_shape: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 1_u64);
  let return_start: own Bool = semantic_reader_writer_head_starts_node(source: source, tokens: tokens, ast: ast, node: node);
  let return_head: own u64 = index<u64>(deref(ast).heads, node);
  let return_word: own Bool = parser_word6(source: source, tokens: tokens, token: return_head, a: 114_u8, b: 101_u8, c: 116_u8, d: 117_u8, e: 114_u8, f: 110_u8);
  let return_first: own Bool = band<Bool>(return_kind, return_shape);
  let return_second: own Bool = band<Bool>(return_start, return_word);
  match band<Bool>(return_first, return_second) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let value: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
  let ast_unit_literal_atom: own AstKind = AstUnitLiteral();
  let value_kind: own Bool = semantic_body_kind_is(ast: ast, node: value, want: ast_unit_literal_atom);
  let value_token: own Bool = semantic_reader_writer_leaf_token_exact(source: source, tokens: tokens, ast: ast, node: value);
  let value_head: own u64 = index<u64>(deref(ast).heads, value);
  let value_word: own Bool = parser_word4(source: source, tokens: tokens, token: value_head, a: 117_u8, b: 110_u8, c: 105_u8, d: 116_u8);
  let value_first: own Bool = band<Bool>(value_kind, value_token);
  let value_valid: own Bool = band<Bool>(value_first, value_word);
  let terminal: own u64 = index<u64>(deref(ast).next_siblings, node);
  let terminated: own Bool = ieq<u64>(terminal, ast_none);
  return band<Bool>(value_valid, terminated);
}

fn semantic_reader_reborrow_outer_signature_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, writes_node: own u64, block: own u64) -> own Bool reads('c), traps {
