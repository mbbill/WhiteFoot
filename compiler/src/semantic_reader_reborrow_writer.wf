  let parameter_type_token: own Bool = semantic_reader_writer_leaf_token_exact(source: source, tokens: tokens, ast: ast, node: parameter_type);
  let parameter_type_id: own u64 = semantic_reader_param_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, parameter: parameter);
  let parameter_struct: own Bool = ige<u64>(parameter_type_id, semantic_reader_struct_type_base);
  let region_ok: own Bool = band<Bool>(mode_region_valid, mode_region_matches);
