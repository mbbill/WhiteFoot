  let regions_shape: own Bool = semantic_body_exact_children(ast: ast, node: region_parameters, want: 1_u64);
  let regions_token: own Bool = semantic_buffer_single_symbol_node(source: source, tokens: tokens, ast: ast, node: region_parameters, want: 91_u8);
