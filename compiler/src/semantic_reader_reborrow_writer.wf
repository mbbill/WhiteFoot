  let outer_region_head: own u64 = index<u64>(deref(ast).heads, outer_region);

  let ast_parameter_atom: own AstKind = AstParameter();
  let parameter_kind: own Bool = semantic_body_kind_is(ast: ast, node: parameter, want: ast_parameter_atom);
  let parameter_shape: own Bool = semantic_body_exact_children(ast: ast, node: parameter, want: 2_u64);
