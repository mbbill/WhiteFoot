fn semantic_reader_reborrow_region_name_unique ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, first: own u64, current: own u64, outer_region_head: own u64) -> own Bool reads('c), traps {
  let current_region: own u64 = semantic_body_child_at(ast: ast, node: current, ordinal: 0_u64);
  let current_head: own u64 = index<u64>(deref(ast).heads, current_region);
  let shadows_outer: own Bool = token_text_equal(source: source, tokens: tokens, left: current_head, right: outer_region_head);
  match shadows_outer {
    True() => {
      return False();
    }
    False() => {
    }
  }
  let ast_count: own u64 = deref(ast).count;
  let prior: own u64 = first;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_reborrow_prior_regions {
    match ieq<u64>(prior, current) {
      True() => {
        return True();
      }
      False() => {
      }
    }
    let prior_shape: own Bool = semantic_reader_reborrow_region_shape_valid(source: source, tokens: tokens, ast: ast, node: prior);
    match prior_shape {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let prior_region: own u64 = semantic_body_child_at(ast: ast, node: prior, ordinal: 0_u64);
    let prior_head: own u64 = index<u64>(deref(ast).heads, prior_region);
    let duplicate: own Bool = token_text_equal(source: source, tokens: tokens, left: prior_head, right: current_head);
    match duplicate {
      True() => {
        return False();
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, prior);
    match ilt<u64>(next, ast_count) {
      True() => {
        set prior = next;
      }
      False() => {
        return False();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }
}

fn semantic_reader_reborrow_writer_region_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, outer_parameter_head: own u64, outer_type: own u64, outer_region_head: own u64, node: own u64) -> own Bool reads('c), traps {
  let region_shape: own Bool = semantic_reader_reborrow_region_shape_valid(source: source, tokens: tokens, ast: ast, node: node);
  match region_shape {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let local_region: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
  let inner_block: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
  let expression_statement: own u64 = semantic_body_child_at(ast: ast, node: inner_block, ordinal: 0_u64);
  let call: own u64 = semantic_body_child_at(ast: ast, node: expression_statement, ordinal: 0_u64);
  let named_argument: own u64 = semantic_body_child_at(ast: ast, node: call, ordinal: 0_u64);
  let child_borrow: own u64 = semantic_body_child_at(ast: ast, node: named_argument, ordinal: 0_u64);
  let child_region: own u64 = semantic_body_child_at(ast: ast, node: child_borrow, ordinal: 0_u64);
  let child_place: own u64 = semantic_body_child_at(ast: ast, node: child_borrow, ordinal: 1_u64);
  let deref_place: own u64 = semantic_body_child_at(ast: ast, node: child_place, ordinal: 0_u64);
  let parent_place: own u64 = semantic_body_child_at(ast: ast, node: deref_place, ordinal: 0_u64);
  let local_region_head: own u64 = index<u64>(deref(ast).heads, local_region);
  let child_region_head: own u64 = index<u64>(deref(ast).heads, child_region);
  let child_region_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: child_region_head, right: local_region_head);
  let local_is_outer: own Bool = token_text_equal(source: source, tokens: tokens, left: local_region_head, right: outer_region_head);
  let local_is_fresh: own Bool = bnot<Bool>(local_is_outer);
  match band<Bool>(child_region_matches, local_is_fresh) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let parent_head: own u64 = index<u64>(deref(ast).heads, parent_place);
  let parent_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: parent_head, right: outer_parameter_head);
  match parent_matches {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let outer_struct_decl: own u64 = isub.wrap<u64>(outer_type, semantic_reader_struct_type_base);
  let outer_struct_valid: own Bool = semantic_reader_struct_decl_valid(ast: ast, struct_decl: outer_struct_decl);
  match outer_struct_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let field_head: own u64 = index<u64>(deref(ast).heads, child_place);
  let field_type: own u64 = semantic_reader_reborrow_struct_field_type(source: source, tokens: tokens, ast: ast, symbols: symbols, struct_decl: outer_struct_decl, field_name_head: field_head);
  match ieq<u64>(field_type, semantic_facts_none) {
    True() => {
      return False();
    }
    False() => {
    }
  }
  return semantic_reader_reborrow_callee_valid(source: source, tokens: tokens, ast: ast, symbols: symbols, call: call, named_argument: named_argument, expected_type: field_type);
}

fn semantic_reader_reborrow_writer_body_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, writes_node: own u64, block: own u64) -> own Bool reads('c), traps {
  let signature_valid: own Bool = semantic_reader_reborrow_outer_signature_valid(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, writes_node: writes_node, block: block);
