  let mode_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: mode);
  let ast_binding_type_atom: own AstKind = AstBindingType();
  let type_valid: own Bool = semantic_buffer_type_node_valid<'c>(source: source, tokens: tokens, ast: ast, node: type_node, kind: ast_binding_type_atom, type_id: semantic_buffer_type_u64);
  let type_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: type_node);
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let initializer_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: initializer, want: ast_numeric_literal_atom);
  let initializer_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: initializer);
  match band<Bool>(initializer_kind, initializer_token) {
    True() => {
    }
    False() => {
      return ast_none;
    }
  }
  let initializer_head: own u64 = index<u64>(deref(ast).heads, initializer);
  let initializer_number: own Bool = parser_kind_at_is<'c>(tokens: tokens, token: initializer_head, want: 6_u64);
  let initializer_start: own u64 = index<u64>(deref(tokens).starts, initializer_head);
  let initializer_end: own u64 = index<u64>(deref(tokens).ends, initializer_head);
  let initializer_width: own u64 = isub.wrap<u64>(initializer_end, initializer_start);
  let initializer_width_valid: own Bool = ieq<u64>(initializer_width, 5_u64);
  let initializer_b0: own Bool = parser_word_byte<'c, 'c>(source: source, tokens: tokens, token: initializer_head, offset: 0_u64, want: 48_u8);
  let initializer_b1: own Bool = parser_word_byte<'c, 'c>(source: source, tokens: tokens, token: initializer_head, offset: 1_u64, want: 95_u8);
  let initializer_b2: own Bool = parser_word_byte<'c, 'c>(source: source, tokens: tokens, token: initializer_head, offset: 2_u64, want: 117_u8);
  let initializer_b3: own Bool = parser_word_byte<'c, 'c>(source: source, tokens: tokens, token: initializer_head, offset: 3_u64, want: 54_u8);
  let initializer_b4: own Bool = parser_word_byte<'c, 'c>(source: source, tokens: tokens, token: initializer_head, offset: 4_u64, want: 52_u8);
  let initializer_b01: own Bool = band<Bool>(initializer_b0, initializer_b1);
  let initializer_b23: own Bool = band<Bool>(initializer_b2, initializer_b3);
  let initializer_first: own Bool = band<Bool>(initializer_b01, initializer_b23);
  let initializer_word: own Bool = band<Bool>(initializer_first, initializer_b4);
  let initializer_prefix: own Bool = band<Bool>(initializer_number, initializer_width_valid);
  let initializer_zero: own Bool = band<Bool>(initializer_prefix, initializer_word);
  let mode_first: own Bool = band<Bool>(mode_kind, mode_valid);
  let mode_and_type: own Bool = band<Bool>(mode_first, mode_token);
  let type_exact: own Bool = band<Bool>(type_valid, type_token);
  let declaration: own Bool = band<Bool>(mode_and_type, type_exact);
  match band<Bool>(declaration, initializer_zero) {
    True() => {
      return index<u64>(deref(ast).heads, name);
    }
    False() => {
      return ast_none;
    }
  }
}

fn semantic_reader_writer_control_guard_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, node: own u64, cursor_head: own u64) -> own Bool reads('c), traps {
