  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let left_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: left, want: ast_place_use_atom);
  let left_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: left);
  let left_head: own u64 = index<u64>(deref(ast).heads, left);
  let left_matches: own Bool = token_text_equal<'c, 'c>(source: source, tokens: tokens, left: left_head, right: cursor_head);
  let left_first: own Bool = band<Bool>(left_kind, left_token);
  let left_valid: own Bool = band<Bool>(left_first, left_matches);
  let right_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: right, want: ast_place_use_atom);
  let right_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: right);
  let right_head: own u64 = index<u64>(deref(ast).heads, right);
  let right_is_cursor: own Bool = token_text_equal<'c, 'c>(source: source, tokens: tokens, left: right_head, right: cursor_head);
  let right_not_cursor: own Bool = bnot<Bool>(right_is_cursor);
  let right_class: own u64 = semantic_reader_writer_own_u64_parameter_class<'c>(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, name_head: right_head);
  let right_parameter: own Bool = ieq<u64>(right_class, 1_u64);
  let right_first: own Bool = band<Bool>(right_kind, right_token);
  let right_second: own Bool = band<Bool>(right_not_cursor, right_parameter);
  let right_valid: own Bool = band<Bool>(right_first, right_second);
  let operands: own Bool = band<Bool>(left_valid, right_valid);
  let type_exact: own Bool = band<Bool>(type_valid, type_token);
  return band<Bool>(type_exact, operands);
