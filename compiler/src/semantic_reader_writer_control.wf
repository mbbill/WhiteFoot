  match operation {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let type_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 0_u64);
  let left: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 1_u64);
  let right: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 2_u64);
