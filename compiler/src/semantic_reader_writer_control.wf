fn semantic_reader_writer_control_leaf_value_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let ast_constructor_atom: own AstKind = AstConstructor();
  let place: own Bool = semantic_body_kind_is<'c>(ast: ast, node: node, want: ast_place_use_atom);
  let numeric: own Bool = semantic_body_kind_is<'c>(ast: ast, node: node, want: ast_numeric_literal_atom);
  let constructor: own Bool = semantic_body_kind_is<'c>(ast: ast, node: node, want: ast_constructor_atom);
  let exact_leaf: own Bool = bor<Bool>(place, numeric);
  match exact_leaf {
    True() => {
      return semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: node);
    }
    False() => {
    }
  }
  match constructor {
    True() => {
      let shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: node, want: 0_u64);
      let token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: node);
      return band<Bool>(shape, token);
    }
    False() => {
      return False();
    }
  }
}

