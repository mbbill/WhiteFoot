fn semantic_reader_writer_control_break_arm_class ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, arm: own u64, loop_label_head: own u64) -> own u64 reads('c), traps {
  let ast_match_arm_atom: own AstKind = AstMatchArm();
  let arm_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: arm, want: ast_match_arm_atom);
  let arm_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: arm, want: 1_u64);
  let arm_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: arm);
  let arm_first: own Bool = band<Bool>(arm_kind, arm_shape);
  match band<Bool>(arm_first, arm_token) {
    True() => {
    }
    False() => {
      return 2_u64;
    }
  }
  let block: own u64 = semantic_body_child_at<'c>(ast: ast, node: arm, ordinal: 0_u64);
  let ast_block_atom: own AstKind = AstBlock();
  let block_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: block, want: ast_block_atom);
  let block_token: own Bool = semantic_buffer_single_symbol_node<'c>(source: source, tokens: tokens, ast: ast, node: block, want: 123_u8);
  match band<Bool>(block_kind, block_token) {
    True() => {
    }
    False() => {
      return 2_u64;
    }
  }
  let first: own u64 = index<u64>(deref(ast).first_children, block);
  let last: own u64 = index<u64>(deref(ast).last_children, block);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  match band<Bool>(first_none, last_none) {
    True() => {
      return 0_u64;
    }
    False() => {
    }
  }
  match ieq<u64>(first, last) {
    True() => {
    }
    False() => {
      return 2_u64;
    }
  }
  let ast_break_atom: own AstKind = AstBreak();
  let break_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: first, want: ast_break_atom);
  let break_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: first, want: 1_u64);
  let break_token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: first);
  let break_first: own Bool = band<Bool>(break_kind, break_shape);
  match band<Bool>(break_first, break_token) {
    True() => {
    }
    False() => {
      return 2_u64;
    }
  }
  let break_head: own u64 = index<u64>(deref(ast).heads, first);
  let break_word: own Bool = parser_word5<'c, 'c>(source: source, tokens: tokens, token: break_head, a: 98_u8, b: 114_u8, c: 101_u8, d: 97_u8, e: 107_u8);
  let break_label: own u64 = semantic_body_child_at<'c>(ast: ast, node: first, ordinal: 0_u64);
  let ast_break_label_atom: own AstKind = AstBreakLabel();
  let label_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: break_label, want: ast_break_label_atom);
  let label_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: break_label);
  let break_label_head: own u64 = index<u64>(deref(ast).heads, break_label);
  let label_matches: own Bool = token_text_equal<'c, 'c>(source: source, tokens: tokens, left: break_label_head, right: loop_label_head);
  let label_first: own Bool = band<Bool>(label_kind, label_token);
  let label_valid: own Bool = band<Bool>(label_first, label_matches);
  match band<Bool>(break_word, label_valid) {
    True() => {
      return 1_u64;
    }
    False() => {
      return 2_u64;
    }
  }
}

fn semantic_reader_writer_control_break_match_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, node: own u64, loop_label_head: own u64, cursor_head: own u64) -> own Bool reads('c), traps {
  let ast_match_atom: own AstKind = AstMatch();
  let kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: node, want: ast_match_atom);
  let shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: node, want: 3_u64);
  let token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: node);
  let first: own Bool = band<Bool>(kind, shape);
  match band<Bool>(first, token) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let match_word: own Bool = parser_word5<'c, 'c>(source: source, tokens: tokens, token: head, a: 109_u8, b: 97_u8, c: 116_u8, d: 99_u8, e: 104_u8);
  let guard: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 0_u64);
  let guard_valid: own Bool = semantic_reader_writer_control_guard_valid<'c>(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, node: guard, cursor_head: cursor_head);
  let break_arm: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 1_u64);
  let empty_arm: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 2_u64);
  let break_arm_token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: break_arm);
  let empty_arm_token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: empty_arm);
  let break_arm_head: own u64 = index<u64>(deref(ast).heads, break_arm);
  let empty_arm_head: own u64 = index<u64>(deref(ast).heads, empty_arm);
  let break_arm_code: own PreludeConstructorCode = semantic_prelude_constructor_code<'c, 'c>(source: source, tokens: tokens, token: break_arm_head);
  let empty_arm_code: own PreludeConstructorCode = semantic_prelude_constructor_code<'c, 'c>(source: source, tokens: tokens, token: empty_arm_head);
  let true_tag: own PreludeConstructorCode = PreludeConstructorTrue();
  let false_tag: own PreludeConstructorCode = PreludeConstructorFalse();
  let break_arm_true: own Bool = eeq<PreludeConstructorCode>(break_arm_code, true_tag);
  let empty_arm_false: own Bool = eeq<PreludeConstructorCode>(empty_arm_code, false_tag);
  let break_class: own u64 = semantic_reader_writer_control_break_arm_class<'c>(source: source, tokens: tokens, ast: ast, arm: break_arm, loop_label_head: loop_label_head);
  let empty_class: own u64 = semantic_reader_writer_control_break_arm_class<'c>(source: source, tokens: tokens, ast: ast, arm: empty_arm, loop_label_head: loop_label_head);
  let break_valid: own Bool = ieq<u64>(break_class, 1_u64);
  let empty_valid: own Bool = ieq<u64>(empty_class, 0_u64);
  let arms: own Bool = band<Bool>(break_valid, empty_valid);
  let arm_tokens: own Bool = band<Bool>(break_arm_token, empty_arm_token);
  let arm_words: own Bool = band<Bool>(break_arm_true, empty_arm_false);
  let arm_headers: own Bool = band<Bool>(arm_tokens, arm_words);
  let exact_arms: own Bool = band<Bool>(arm_headers, arms);
  let header: own Bool = band<Bool>(match_word, guard_valid);
  return band<Bool>(header, exact_arms);
}

fn semantic_reader_writer_control_loop_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, writes_region_head: own u64, cursor_head: own u64, node: own u64) -> own Bool reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  let ast_loop_atom: own AstKind = AstLoop();
  let kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: node, want: ast_loop_atom);
  let shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: node, want: 2_u64);
  let token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: node);
  let first: own Bool = band<Bool>(kind, shape);
