  let head: own u64 = index<u64>(deref(ast).heads, node);
  let loop_word: own Bool = parser_word4<'c, 'c>(source: source, tokens: tokens, token: head, a: 108_u8, b: 111_u8, c: 111_u8, d: 112_u8);
  let label: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 0_u64);
  let ast_loop_label_atom: own AstKind = AstLoopLabel();
  let label_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: label, want: ast_loop_label_atom);
  let label_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: label);
  let label_valid: own Bool = band<Bool>(label_kind, label_token);
  match band<Bool>(loop_word, label_valid) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let loop_label_head: own u64 = index<u64>(deref(ast).heads, label);
  let block: own u64 = semantic_body_child_at<'c>(ast: ast, node: node, ordinal: 1_u64);
  let ast_block_atom: own AstKind = AstBlock();
  let block_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: block, want: ast_block_atom);
  let block_token: own Bool = semantic_buffer_single_symbol_node<'c>(source: source, tokens: tokens, ast: ast, node: block, want: 123_u8);
  match band<Bool>(block_kind, block_token) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let statement: own u64 = index<u64>(deref(ast).first_children, block);
  let last: own u64 = index<u64>(deref(ast).last_children, block);
  let break_match_valid: own Bool = semantic_reader_writer_control_break_match_valid<'c>(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, node: statement, loop_label_head: loop_label_head, cursor_head: cursor_head);
  match break_match_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let next_statement: own u64 = index<u64>(deref(ast).next_siblings, statement);
  match ilt<u64>(next_statement, ast_count) {
    True() => {
      set statement = next_statement;
    }
    False() => {
      return False();
    }
  }
  let index_count: own u64 = 0_u64;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_writer_control_index_sets {
    match ieq<u64>(statement, last) {
      True() => {
        break @semantic_reader_writer_control_index_sets;
      }
      False() => {
      }
    }
    let set_valid: own Bool = semantic_reader_writer_control_set_header_valid<'c>(source: source, tokens: tokens, ast: ast, node: statement);
    match set_valid {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let target: own u64 = semantic_body_child_at<'c>(ast: ast, node: statement, ordinal: 0_u64);
    let target_shape_valid: own Bool = semantic_reader_writer_index_target_valid<'c>(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, writes_region_head: writes_region_head, local_subscript_head: cursor_head, target: target);
    match target_shape_valid {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let subscript: own u64 = semantic_body_child_at<'c>(ast: ast, node: target, ordinal: 2_u64);
    let subscript_head: own u64 = index<u64>(deref(ast).heads, subscript);
    let subscript_matches: own Bool = token_text_equal<'c, 'c>(source: source, tokens: tokens, left: subscript_head, right: cursor_head);
    let target_valid: own Bool = subscript_matches;
    let value: own u64 = semantic_body_child_at<'c>(ast: ast, node: statement, ordinal: 1_u64);
    let value_valid: own Bool = semantic_reader_writer_control_leaf_value_valid<'c>(source: source, tokens: tokens, ast: ast, node: value);
    match band<Bool>(target_valid, value_valid) {
      True() => {
        set index_count = iadd.trap<u64>(index_count, 1_u64);
      }
      False() => {
        return False();
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, statement);
    match ilt<u64>(next, ast_count) {
      True() => {
        set statement = next;
      }
      False() => {
        return False();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }
  match igt<u64>(index_count, 0_u64) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let local_set_valid: own Bool = semantic_reader_writer_control_set_header_valid<'c>(source: source, tokens: tokens, ast: ast, node: last);
  match local_set_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let local_target: own u64 = semantic_body_child_at<'c>(ast: ast, node: last, ordinal: 0_u64);
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let local_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: local_target, want: ast_place_use_atom);
  let local_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: local_target);
  let local_head: own u64 = index<u64>(deref(ast).heads, local_target);
  let local_matches: own Bool = token_text_equal<'c, 'c>(source: source, tokens: tokens, left: local_head, right: cursor_head);
  let local_first: own Bool = band<Bool>(local_kind, local_token);
  let local_valid: own Bool = band<Bool>(local_first, local_matches);
  let local_value: own u64 = semantic_body_child_at<'c>(ast: ast, node: last, ordinal: 1_u64);
  let increment_valid: own Bool = semantic_reader_writer_control_iadd_valid<'c>(source: source, tokens: tokens, ast: ast, node: local_value, cursor_head: cursor_head);
  let terminal: own u64 = index<u64>(deref(ast).next_siblings, last);
  let terminated: own Bool = ieq<u64>(terminal, ast_none);
  let update_valid: own Bool = band<Bool>(local_valid, increment_valid);
  return band<Bool>(update_valid, terminated);
}

fn semantic_reader_writer_control_body_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, writes_node: own u64, block: own u64) -> own Bool reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  let function_valid: own Bool = ilt<u64>(function, ast_count);
  let writes_valid: own Bool = ilt<u64>(writes_node, ast_count);
  let block_valid: own Bool = ilt<u64>(block, ast_count);
  let first_valid: own Bool = band<Bool>(function_valid, writes_valid);
  match band<Bool>(first_valid, block_valid) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let ast_block_atom: own AstKind = AstBlock();
  let block_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: block, want: ast_block_atom);
  let block_token: own Bool = semantic_buffer_single_symbol_node<'c>(source: source, tokens: tokens, ast: ast, node: block, want: 123_u8);
  match band<Bool>(block_kind, block_token) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let writes_first: own u64 = index<u64>(deref(ast).first_children, writes_node);
  let writes_last: own u64 = index<u64>(deref(ast).last_children, writes_node);
  let writes_one: own Bool = ieq<u64>(writes_first, writes_last);
  let writes_present: own Bool = ine<u64>(writes_first, ast_none);
  match band<Bool>(writes_one, writes_present) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let region_valid: own Bool = semantic_function_region_leaf_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: writes_first);
  match region_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let writes_region_head: own u64 = index<u64>(deref(ast).heads, writes_first);
  let statement: own u64 = index<u64>(deref(ast).first_children, block);
  let last: own u64 = index<u64>(deref(ast).last_children, block);
  let statement_valid: own Bool = ilt<u64>(statement, ast_count);
  let last_valid: own Bool = ilt<u64>(last, ast_count);
  match band<Bool>(statement_valid, last_valid) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let cursor_head: own u64 = semantic_reader_writer_control_cursor_head<'c>(source: source, tokens: tokens, ast: ast, node: statement);
  match ieq<u64>(cursor_head, ast_none) {
    True() => {
      return False();
    }
    False() => {
    }
  }
  let loop_node: own u64 = index<u64>(deref(ast).next_siblings, statement);
  match ilt<u64>(loop_node, ast_count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let loop_valid: own Bool = semantic_reader_writer_control_loop_valid<'c>(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, writes_region_head: writes_region_head, cursor_head: cursor_head, node: loop_node);
  match loop_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let tail: own u64 = index<u64>(deref(ast).next_siblings, loop_node);
  let tail_count: own u64 = 0_u64;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_writer_control_tail_sets {
    match ieq<u64>(tail, last) {
      True() => {
        break @semantic_reader_writer_control_tail_sets;
      }
      False() => {
      }
    }
    match ilt<u64>(tail, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let set_valid: own Bool = semantic_reader_writer_control_set_header_valid<'c>(source: source, tokens: tokens, ast: ast, node: tail);
    match set_valid {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let target: own u64 = semantic_body_child_at<'c>(ast: ast, node: tail, ordinal: 0_u64);
    let target_valid: own Bool = semantic_reader_writer_field_target_valid<'c>(source: source, tokens: tokens, ast: ast, function: function, writes_region_head: writes_region_head, target: target);
    let value: own u64 = semantic_body_child_at<'c>(ast: ast, node: tail, ordinal: 1_u64);
    let value_valid: own Bool = semantic_reader_writer_control_leaf_value_valid<'c>(source: source, tokens: tokens, ast: ast, node: value);
    match band<Bool>(target_valid, value_valid) {
      True() => {
        set tail_count = iadd.trap<u64>(tail_count, 1_u64);
      }
      False() => {
        return False();
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, tail);
    match ilt<u64>(next, ast_count) {
      True() => {
        set tail = next;
      }
      False() => {
        return False();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }
  match igt<u64>(tail_count, 0_u64) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let ast_return_atom: own AstKind = AstReturn();
  let return_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: last, want: ast_return_atom);
  let return_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: last, want: 1_u64);
  let return_token: own Bool = semantic_reader_writer_head_starts_node<'c>(source: source, tokens: tokens, ast: ast, node: last);
  let return_first: own Bool = band<Bool>(return_kind, return_shape);
  match band<Bool>(return_first, return_token) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let return_head: own u64 = index<u64>(deref(ast).heads, last);
  let return_word: own Bool = parser_word6<'c, 'c>(source: source, tokens: tokens, token: return_head, a: 114_u8, b: 101_u8, c: 116_u8, d: 117_u8, e: 114_u8, f: 110_u8);
  let return_value: own u64 = semantic_body_child_at<'c>(ast: ast, node: last, ordinal: 0_u64);
  let ast_unit_literal_atom: own AstKind = AstUnitLiteral();
  let unit_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: return_value, want: ast_unit_literal_atom);
  let unit_token: own Bool = semantic_reader_writer_leaf_token_exact<'c>(source: source, tokens: tokens, ast: ast, node: return_value);
  let unit_head: own u64 = index<u64>(deref(ast).heads, return_value);
  let unit_word: own Bool = parser_word4<'c, 'c>(source: source, tokens: tokens, token: unit_head, a: 117_u8, b: 110_u8, c: 105_u8, d: 116_u8);
  let unit_first: own Bool = band<Bool>(unit_kind, unit_token);
  let unit_valid: own Bool = band<Bool>(unit_first, unit_word);
  let terminal: own u64 = index<u64>(deref(ast).next_siblings, last);
  let terminated: own Bool = ieq<u64>(terminal, ast_none);
  let return_valid: own Bool = band<Bool>(return_word, unit_valid);
  return band<Bool>(return_valid, terminated);
}
