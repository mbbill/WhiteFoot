fn llvm_buffer_fact_row_valid ['f] (facts: &'f NodeFacts, node: own u64, type_id: own u64, resolution: own u64, ordinal: own u64, operation: own SemanticOperation, constant: own u64, target: own u64, mode: own SemanticValueMode, prelude: own PreludeConstructorCode) -> own Bool reads('f), traps {
  match ilt<u64>(node, deref(facts).count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let type_ok: own Bool = ieq<u64>(index<u64>(deref(facts).type_ids, node), type_id);
  let resolution_ok: own Bool = ieq<u64>(index<u64>(deref(facts).resolved_declarations, node), resolution);
  let ordinal_ok: own Bool = ieq<u64>(index<u64>(deref(facts).ordinals, node), ordinal);
  let operation_ok: own Bool = ieq<SemanticOperation>(index<SemanticOperation>(deref(facts).operations, node), operation);
  let constant_ok: own Bool = ieq<u64>(index<u64>(deref(facts).constant_values, node), constant);
  let target_ok: own Bool = ieq<u64>(index<u64>(deref(facts).control_targets, node), target);
  let mode_ok: own Bool = ieq<SemanticValueMode>(index<SemanticValueMode>(deref(facts).modes, node), mode);
  let prelude_ok: own Bool = ieq<PreludeConstructorCode>(index<PreludeConstructorCode>(deref(facts).prelude_constructors, node), prelude);
  let p0: own Bool = band<Bool>(type_ok, resolution_ok);
  let p1: own Bool = band<Bool>(ordinal_ok, operation_ok);
  let p2: own Bool = band<Bool>(constant_ok, target_ok);
  let p3: own Bool = band<Bool>(mode_ok, prelude_ok);
  let q0: own Bool = band<Bool>(p0, p1);
  let q1: own Bool = band<Bool>(p2, p3);
  return band<Bool>(q0, q1);
}

fn llvm_buffer_default_fact_row ['f] (facts: &'f NodeFacts, node: own u64) -> own Bool reads('f), traps {
  return llvm_buffer_fact_row_valid(facts: facts, node: node, type_id: semantic_facts_none, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeNone(), prelude: PreludeConstructorUnknown());
}

fn llvm_buffer_typed_fact_row ['f] (facts: &'f NodeFacts, node: own u64, type_id: own u64) -> own Bool reads('f), traps {
  return llvm_buffer_fact_row_valid(facts: facts, node: node, type_id: type_id, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeNone(), prelude: PreludeConstructorUnknown());
}

fn llvm_buffer_parameter_facts_valid ['a, 'f] (ast: &'a AstTape, facts: &'f NodeFacts, parameter: own u64, type_id: own u64, ordinal: own u64, mode: own SemanticValueMode) -> own Bool reads('a 'f), traps {
  let mode_node: own u64 = llvm_linear_child_at(ast: ast, node: parameter, ordinal: 0_u64);
  let type_node: own u64 = llvm_linear_child_at(ast: ast, node: parameter, ordinal: 1_u64);
  let parameter_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: parameter, type_id: type_id, resolution: semantic_facts_none, ordinal: ordinal, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: mode, prelude: PreludeConstructorUnknown());
  let mode_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: mode_node, type_id: type_id, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: mode, prelude: PreludeConstructorUnknown());
  let type_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: type_node, type_id: type_id);
  let first: own Bool = band<Bool>(parameter_row, mode_row);
  match ieq<u64>(type_id, semantic_buffer_type_u8_buffer) {
    True() => {
      let region_node: own u64 = llvm_linear_child_at(ast: ast, node: mode_node, ordinal: 0_u64);
      let element: own u64 = llvm_linear_child_at(ast: ast, node: type_node, ordinal: 0_u64);
      let region_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: region_node);
      let element_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: element, type_id: semantic_buffer_type_u8);
      let parameter_and_type: own Bool = band<Bool>(first, type_row);
      let region_and_element: own Bool = band<Bool>(region_row, element_row);
      return band<Bool>(parameter_and_type, region_and_element);
    }
    False() => {
      return band<Bool>(first, type_row);
    }
  }
}

fn llvm_buffer_let_facts_valid ['a, 'f] (ast: &'a AstTape, facts: &'f NodeFacts, declaration: own u64, type_id: own u64, ordinal: own u64) -> own Bool reads('a 'f), traps {
  let name: own u64 = llvm_linear_child_at(ast: ast, node: declaration, ordinal: 0_u64);
  let mode_node: own u64 = llvm_linear_child_at(ast: ast, node: declaration, ordinal: 1_u64);
  let type_node: own u64 = llvm_linear_child_at(ast: ast, node: declaration, ordinal: 2_u64);
  let declaration_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: declaration, type_id: type_id, resolution: semantic_facts_none, ordinal: ordinal, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeOwn(), prelude: PreludeConstructorUnknown());
  let name_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: name, type_id: type_id);
  let mode_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: mode_node, type_id: type_id, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeOwn(), prelude: PreludeConstructorUnknown());
  let type_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: type_node, type_id: type_id);
  let first: own Bool = band<Bool>(declaration_row, name_row);
  let second: own Bool = band<Bool>(mode_row, type_row);
  return band<Bool>(first, second);
}

fn llvm_buffer_place_fact_valid ['f] (facts: &'f NodeFacts, node: own u64, type_id: own u64, declaration: own u64, mode: own SemanticValueMode) -> own Bool reads('f), traps {
  return llvm_buffer_fact_row_valid(facts: facts, node: node, type_id: type_id, resolution: declaration, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: mode, prelude: PreludeConstructorUnknown());
