    let array_length: own Bool = ieq<u64>(index<u64>(deref(types).array_lengths, row), semantic_facts_none);
    let source_node: own Bool = ieq<u64>(index<u64>(deref(types).source_nodes, row), semantic_facts_none);
    let remaining_defaults: own Bool = band<Bool>(array_length, source_node);
    let defaults: own Bool = band<Bool>(declaration, remaining_defaults);
    match defaults {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let expected_element: own u64 = semantic_facts_none;
    match ieq<u64>(row, 3_u64) {
      True() => {
        set expected_element = semantic_buffer_type_u8;
      }
      False() => {
      }
    }
    match ieq<u64>(index<u64>(deref(types).element_types, row), expected_element) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let expected_prelude: own PreludeTypeCode = PreludeTypeUnknown();
    match ieq<u64>(row, 1_u64) {
      True() => {
        set expected_prelude = PreludeTypeBool();
      }
      False() => {
      }
    }
    match ieq<PreludeTypeCode>(index<PreludeTypeCode>(deref(types).prelude_types, row), expected_prelude) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    match ieq<u64>(row, 3_u64) {
      True() => {
        return True();
      }
      False() => {
        set row = iadd.trap<u64>(row, 1_u64);
      }
    }
  }
}

fn llvm_buffer_match3_facts_valid ['s, 't, 'a, 'y, 'f] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts) -> own Bool reads('s 't 'a 'y 'f), traps {
  let body_valid: own Bool = semantic_buffer_match3_body_valid(source: source, tokens: tokens, ast: ast, function: function);
  match body_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let type_shape: own Bool = semantic_type_tape_shape_valid(types: types);
  let fact_shape: own Bool = semantic_node_facts_shape_valid(facts: facts);
  let clean_tag: own SemanticFactsStatus = SemanticFactsClean();
  let types_clean: own Bool = ieq<SemanticFactsStatus>(deref(types).status, clean_tag);
  let facts_clean: own Bool = ieq<SemanticFactsStatus>(deref(facts).status, clean_tag);
  let facts_dense: own Bool = ieq<u64>(deref(facts).count, deref(ast).count);
  let type_node_clean: own Bool = ieq<u64>(deref(types).node, semantic_facts_none);
  let type_related_clean: own Bool = ieq<u64>(deref(types).related, semantic_facts_none);
  let fact_node_clean: own Bool = ieq<u64>(deref(facts).node, semantic_facts_none);
  let fact_related_clean: own Bool = ieq<u64>(deref(facts).related, semantic_facts_none);
  let shapes: own Bool = band<Bool>(type_shape, fact_shape);
  let statuses: own Bool = band<Bool>(types_clean, facts_clean);
  let type_metadata: own Bool = band<Bool>(type_node_clean, type_related_clean);
  let fact_metadata: own Bool = band<Bool>(fact_node_clean, fact_related_clean);
  let shape_status: own Bool = band<Bool>(shapes, statuses);
  let clean_metadata: own Bool = band<Bool>(type_metadata, fact_metadata);
  let tapes_clean: own Bool = band<Bool>(shape_status, clean_metadata);
  let tapes_valid: own Bool = band<Bool>(tapes_clean, facts_dense);
  match tapes_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let type_rows: own Bool = llvm_buffer_type_rows_valid(types: types);
  match type_rows {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let root: own u64 = deref(ast).root;
  let name: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 0_u64);
  let regions: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 1_u64);
  let source_parameter: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 2_u64);
  let start_parameter: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 3_u64);
  let a_parameter: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 4_u64);
  let b_parameter: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 5_u64);
  let c_parameter: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 6_u64);
  let return_mode: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 7_u64);
  let return_type: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 8_u64);
  let reads_effect: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 9_u64);
  let traps_effect: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 10_u64);
  let block: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 11_u64);
  let declared_region: own u64 = llvm_linear_child_at(ast: ast, node: regions, ordinal: 0_u64);
  let read_region: own u64 = llvm_linear_child_at(ast: ast, node: reads_effect, ordinal: 0_u64);

  let root_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: root);
  let function_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: function);
  let name_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: name);
  let regions_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: regions);
  let declared_region_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: declared_region);
  let reads_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: reads_effect);
  let read_region_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: read_region);
  let traps_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: traps_effect);
  let block_row: own Bool = llvm_buffer_default_fact_row(facts: facts, node: block);
  let header0: own Bool = band<Bool>(root_row, function_row);
  let header1: own Bool = band<Bool>(name_row, regions_row);
  let header2: own Bool = band<Bool>(declared_region_row, reads_row);
  let header3: own Bool = band<Bool>(read_region_row, traps_row);
  let header01: own Bool = band<Bool>(header0, header1);
  let header23: own Bool = band<Bool>(header2, header3);
  let header03: own Bool = band<Bool>(header01, header23);
  let structural_header: own Bool = band<Bool>(header03, block_row);
  match structural_header {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let source_parameter_rows: own Bool = llvm_buffer_parameter_facts_valid(ast: ast, facts: facts, parameter: source_parameter, type_id: semantic_buffer_type_u8_buffer, ordinal: 0_u64, mode: SemanticModeShared());
  let start_parameter_rows: own Bool = llvm_buffer_parameter_facts_valid(ast: ast, facts: facts, parameter: start_parameter, type_id: semantic_buffer_type_u64, ordinal: 1_u64, mode: SemanticModeOwn());
  let a_parameter_rows: own Bool = llvm_buffer_parameter_facts_valid(ast: ast, facts: facts, parameter: a_parameter, type_id: semantic_buffer_type_u8, ordinal: 2_u64, mode: SemanticModeOwn());
  let b_parameter_rows: own Bool = llvm_buffer_parameter_facts_valid(ast: ast, facts: facts, parameter: b_parameter, type_id: semantic_buffer_type_u8, ordinal: 3_u64, mode: SemanticModeOwn());
  let c_parameter_rows: own Bool = llvm_buffer_parameter_facts_valid(ast: ast, facts: facts, parameter: c_parameter, type_id: semantic_buffer_type_u8, ordinal: 4_u64, mode: SemanticModeOwn());
  let return_mode_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: return_mode, type_id: semantic_buffer_type_bool, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeOwn(), prelude: PreludeConstructorUnknown());
  let return_type_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: return_type, type_id: semantic_buffer_type_bool);
  let parameters0: own Bool = band<Bool>(source_parameter_rows, start_parameter_rows);
  let parameters1: own Bool = band<Bool>(a_parameter_rows, b_parameter_rows);
  let parameters2: own Bool = band<Bool>(c_parameter_rows, return_mode_row);
  let parameters01: own Bool = band<Bool>(parameters0, parameters1);
  let parameters23: own Bool = band<Bool>(parameters2, return_type_row);
  let signature_rows: own Bool = band<Bool>(parameters01, parameters23);
  match signature_rows {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let p1_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 0_u64);
  let p2_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 1_u64);
  let b0_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 2_u64);
  let b1_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 3_u64);
  let b2_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 4_u64);
  let e0_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 5_u64);
  let e1_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 6_u64);
  let e2_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 7_u64);
  let first_let: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 8_u64);
  let final_return: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: 9_u64);

  let p1_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: p1_let, type_id: semantic_buffer_type_u64, ordinal: 0_u64);
  let p2_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: p2_let, type_id: semantic_buffer_type_u64, ordinal: 1_u64);
  let b0_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: b0_let, type_id: semantic_buffer_type_u8, ordinal: 2_u64);
  let b1_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: b1_let, type_id: semantic_buffer_type_u8, ordinal: 3_u64);
  let b2_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: b2_let, type_id: semantic_buffer_type_u8, ordinal: 4_u64);
  let e0_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: e0_let, type_id: semantic_buffer_type_bool, ordinal: 5_u64);
  let e1_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: e1_let, type_id: semantic_buffer_type_bool, ordinal: 6_u64);
  let e2_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: e2_let, type_id: semantic_buffer_type_bool, ordinal: 7_u64);
  let first_let_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: first_let, type_id: semantic_buffer_type_bool, ordinal: 8_u64);
  let lets0: own Bool = band<Bool>(p1_let_rows, p2_let_rows);
  let lets1: own Bool = band<Bool>(b0_let_rows, b1_let_rows);
  let lets2: own Bool = band<Bool>(b2_let_rows, e0_let_rows);
  let lets3: own Bool = band<Bool>(e1_let_rows, e2_let_rows);
  let lets01: own Bool = band<Bool>(lets0, lets1);
  let lets23: own Bool = band<Bool>(lets2, lets3);
  let lets07: own Bool = band<Bool>(lets01, lets23);
  let let_rows: own Bool = band<Bool>(lets07, first_let_rows);
  match let_rows {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let p1_value: own u64 = llvm_linear_child_at(ast: ast, node: p1_let, ordinal: 3_u64);
  let p2_value: own u64 = llvm_linear_child_at(ast: ast, node: p2_let, ordinal: 3_u64);
  let b0_value: own u64 = llvm_linear_child_at(ast: ast, node: b0_let, ordinal: 3_u64);
  let b1_value: own u64 = llvm_linear_child_at(ast: ast, node: b1_let, ordinal: 3_u64);
  let b2_value: own u64 = llvm_linear_child_at(ast: ast, node: b2_let, ordinal: 3_u64);
  let e0_value: own u64 = llvm_linear_child_at(ast: ast, node: e0_let, ordinal: 3_u64);
  let e1_value: own u64 = llvm_linear_child_at(ast: ast, node: e1_let, ordinal: 3_u64);
  let e2_value: own u64 = llvm_linear_child_at(ast: ast, node: e2_let, ordinal: 3_u64);
  let first_value: own u64 = llvm_linear_child_at(ast: ast, node: first_let, ordinal: 3_u64);
  let final_value: own u64 = llvm_linear_child_at(ast: ast, node: final_return, ordinal: 0_u64);

  let p1_rows: own Bool = llvm_buffer_iadd_facts_valid(ast: ast, facts: facts, call: p1_value, ordinal: 0_u64, left_declaration: start_parameter, literal_value: 1_u64);
  let p2_rows: own Bool = llvm_buffer_iadd_facts_valid(ast: ast, facts: facts, call: p2_value, ordinal: 1_u64, left_declaration: start_parameter, literal_value: 2_u64);
  let b0_rows: own Bool = llvm_buffer_index_facts_valid(ast: ast, facts: facts, node: b0_value, ordinal: 2_u64, source_declaration: source_parameter, subscript_declaration: start_parameter);
  let b1_rows: own Bool = llvm_buffer_index_facts_valid(ast: ast, facts: facts, node: b1_value, ordinal: 3_u64, source_declaration: source_parameter, subscript_declaration: p1_let);
  let b2_rows: own Bool = llvm_buffer_index_facts_valid(ast: ast, facts: facts, node: b2_value, ordinal: 4_u64, source_declaration: source_parameter, subscript_declaration: p2_let);
  let e0_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: e0_value, ordinal: 5_u64, operand_type: semantic_buffer_type_u8, operation: SemanticOperationIeq(), left_declaration: b0_let, right_declaration: a_parameter);
  let e1_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: e1_value, ordinal: 6_u64, operand_type: semantic_buffer_type_u8, operation: SemanticOperationIeq(), left_declaration: b1_let, right_declaration: b_parameter);
  let e2_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: e2_value, ordinal: 7_u64, operand_type: semantic_buffer_type_u8, operation: SemanticOperationIeq(), left_declaration: b2_let, right_declaration: c_parameter);
  let first_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: first_value, ordinal: 8_u64, operand_type: semantic_buffer_type_bool, operation: SemanticOperationBand(), left_declaration: e0_let, right_declaration: e1_let);
  let final_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: final_value, ordinal: 9_u64, operand_type: semantic_buffer_type_bool, operation: SemanticOperationBand(), left_declaration: first_let, right_declaration: e2_let);
  let final_return_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: final_return, type_id: semantic_buffer_type_bool, resolution: semantic_facts_none, ordinal: 9_u64, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeOwn(), prelude: PreludeConstructorUnknown());
  let values0: own Bool = band<Bool>(p1_rows, p2_rows);
  let values1: own Bool = band<Bool>(b0_rows, b1_rows);
  let values2: own Bool = band<Bool>(b2_rows, e0_rows);
  let values3: own Bool = band<Bool>(e1_rows, e2_rows);
  let values4: own Bool = band<Bool>(first_rows, final_rows);
  let values01: own Bool = band<Bool>(values0, values1);
  let values23: own Bool = band<Bool>(values2, values3);
  let values03: own Bool = band<Bool>(values01, values23);
  let values49: own Bool = band<Bool>(values4, final_return_row);
  return band<Bool>(values03, values49);
}

fn llvm_buffer_match3_append_ready ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &'o ByteTape) -> own Bool reads('s 't 'a 'y 'f 'o), traps {
  let appendable: own Bool = False();
  let source_size: own u64 = len<u8>(deref(source));
  let ast_nodes: own u64 = deref(ast).count;
  region 'llvm_buffer_ready_state {
    set appendable = llvm_linear_output_appendable(out: &'llvm_buffer_ready_state deref(out), source_size: source_size, ast_nodes: ast_nodes);
  }
  match appendable {
    True() => {
    }
    False() => {
      return False();
    }
  }
  return llvm_buffer_match3_facts_valid(source: source, tokens: tokens, ast: ast, function: function, types: types, facts: facts);
}

fn llvm_buffer_emit_validated_match3_function ['s, 't, 'a, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'o), writes('o), traps {
  region 'llvm_buffer_validated_header {
    llvm_buffer_emit_header(source: source, tokens: tokens, ast: ast, function: function, out: &uniq 'llvm_buffer_validated_header deref(out));
  }
  region 'llvm_buffer_validated_body {
    llvm_buffer_emit_match3_body(out: &uniq 'llvm_buffer_validated_body deref(out));
  }
  return unit;
}

fn llvm_buffer_append_match3 ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  match ieq<ByteStatus>(deref(out).status, ByteInvalidState()) {
    True() => {
      return unit;
    }
    False() => {
    }
  }
  let ready: own Bool = False();
  region 'llvm_buffer_append_ready {
    set ready = llvm_buffer_match3_append_ready(source: source, tokens: tokens, ast: ast, function: function, types: types, facts: facts, out: &'llvm_buffer_append_ready deref(out));
  }
  match ready {
    True() => {
    }
    False() => {
      region 'llvm_buffer_append_bad_input {
        llvm_buffer_fail(out: &uniq 'llvm_buffer_append_bad_input deref(out));
      }
      return unit;
    }
  }
  region 'llvm_buffer_append_function {
    llvm_buffer_emit_validated_match3_function(source: source, tokens: tokens, ast: ast, function: function, out: &uniq 'llvm_buffer_append_function deref(out));
  }
  return unit;
}

fn llvm_buffer_emit_match3 ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  region 'llvm_buffer_emit_reset {
    byte_tape_reset(out: &uniq 'llvm_buffer_emit_reset deref(out));
  }
  let ready: own Bool = False();
  region 'llvm_buffer_emit_ready {
    set ready = llvm_buffer_match3_append_ready(source: source, tokens: tokens, ast: ast, function: function, types: types, facts: facts, out: &'llvm_buffer_emit_ready deref(out));
  }
  match ready {
    True() => {
    }
    False() => {
      region 'llvm_buffer_emit_bad_input {
        llvm_buffer_fail(out: &uniq 'llvm_buffer_emit_bad_input deref(out));
      }
      return unit;
    }
  }
  region 'llvm_buffer_emit_prelude {
    llvm_buffer_emit_prelude(out: &uniq 'llvm_buffer_emit_prelude deref(out));
  }
  region 'llvm_buffer_emit_function {
    llvm_buffer_emit_validated_match3_function(source: source, tokens: tokens, ast: ast, function: function, out: &uniq 'llvm_buffer_emit_function deref(out));
  }
  return unit;
}
