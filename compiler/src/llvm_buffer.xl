  let right_row: own Bool = llvm_buffer_place_fact_valid(facts: facts, node: right, type_id: operand_type, declaration: right_declaration, mode: SemanticModeOwn());
  let first: own Bool = band<Bool>(result_row, type_row);
  let second: own Bool = band<Bool>(left_row, right_row);
  return band<Bool>(first, second);
}

