fn llvm_buffer_iadd_facts_valid ['a, 'f] (ast: &'a AstTape, facts: &'f NodeFacts, call: own u64, ordinal: own u64, left_declaration: own u64, literal_value: own u64) -> own Bool reads('a 'f), traps {
  let type_node: own u64 = llvm_linear_child_at(ast: ast, node: call, ordinal: 0_u64);
  let left: own u64 = llvm_linear_child_at(ast: ast, node: call, ordinal: 1_u64);
  let literal: own u64 = llvm_linear_child_at(ast: ast, node: call, ordinal: 2_u64);
  let result_row: own Bool = llvm_buffer_result_fact_valid(facts: facts, node: call, type_id: semantic_buffer_type_u64, ordinal: ordinal, operation: SemanticOperationIaddTrap());
  let type_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: type_node, type_id: semantic_buffer_type_u64);
  let left_row: own Bool = llvm_buffer_place_fact_valid(facts: facts, node: left, type_id: semantic_buffer_type_u64, declaration: left_declaration, mode: SemanticModeOwn());
  let literal_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: literal, type_id: semantic_buffer_type_u64, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: literal_value, target: semantic_facts_none, mode: SemanticModeOwn(), prelude: PreludeConstructorUnknown());
  let first: own Bool = band<Bool>(result_row, type_row);
  let second: own Bool = band<Bool>(left_row, literal_row);
  return band<Bool>(first, second);
}

fn llvm_buffer_index_facts_valid ['a, 'f] (ast: &'a AstTape, facts: &'f NodeFacts, node: own u64, ordinal: own u64, source_declaration: own u64, subscript_declaration: own u64) -> own Bool reads('a 'f), traps {
  let type_node: own u64 = llvm_linear_child_at(ast: ast, node: node, ordinal: 0_u64);
  let deref_node: own u64 = llvm_linear_child_at(ast: ast, node: node, ordinal: 1_u64);
  let subscript: own u64 = llvm_linear_child_at(ast: ast, node: node, ordinal: 2_u64);
  let source_place: own u64 = llvm_linear_child_at(ast: ast, node: deref_node, ordinal: 0_u64);
  let result_row: own Bool = llvm_buffer_result_fact_valid(facts: facts, node: node, type_id: semantic_buffer_type_u8, ordinal: ordinal, operation: SemanticOperationNone());
  let type_row: own Bool = llvm_buffer_typed_fact_row(facts: facts, node: type_node, type_id: semantic_buffer_type_u8);
  let deref_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: deref_node, type_id: semantic_buffer_type_u8_buffer, resolution: semantic_facts_none, ordinal: semantic_facts_none, operation: SemanticOperationNone(), constant: semantic_facts_none, target: semantic_facts_none, mode: SemanticModeShared(), prelude: PreludeConstructorUnknown());
  let source_row: own Bool = llvm_buffer_place_fact_valid(facts: facts, node: source_place, type_id: semantic_buffer_type_u8_buffer, declaration: source_declaration, mode: SemanticModeShared());
  let subscript_row: own Bool = llvm_buffer_place_fact_valid(facts: facts, node: subscript, type_id: semantic_buffer_type_u64, declaration: subscript_declaration, mode: SemanticModeOwn());
  let first: own Bool = band<Bool>(result_row, type_row);
  let second: own Bool = band<Bool>(deref_row, source_row);
  let roots: own Bool = band<Bool>(first, second);
  return band<Bool>(roots, subscript_row);
}

fn llvm_buffer_binary_facts_valid ['a, 'f] (ast: &'a AstTape, facts: &'f NodeFacts, call: own u64, ordinal: own u64, operand_type: own u64, operation: own SemanticOperation, left_declaration: own u64, right_declaration: own u64) -> own Bool reads('a 'f), traps {
