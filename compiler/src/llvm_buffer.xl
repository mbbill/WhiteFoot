  let kind1: own Bool = ieq<SemanticTypeKind>(index<SemanticTypeKind>(deref(types).kinds, 1_u64), SemanticTypeBool());
  let kind2: own Bool = ieq<SemanticTypeKind>(index<SemanticTypeKind>(deref(types).kinds, 2_u64), SemanticTypeU64());
  let kind3: own Bool = ieq<SemanticTypeKind>(index<SemanticTypeKind>(deref(types).kinds, 3_u64), SemanticTypeBuffer());
  let kinds01: own Bool = band<Bool>(kind0, kind1);
  let kinds23: own Bool = band<Bool>(kind2, kind3);
  let kinds: own Bool = band<Bool>(kinds01, kinds23);
