+def _certify_guarded_bit_window(f, consts):
+    """Certify the one experimental six-symbol, 64-bit bit-window lowering."""
+    digest = _guarded_bit_window_shape_digest(f, consts)
+    if digest != _GUARDED_BIT_WINDOW_SHAPE_SHA256:
+        return None
+    if len(consts) != 1 or consts[0]["ty"] != "array<u32,512>":
+        return None
+    entries = [_litval(value) for value in consts[0]["vals"]]
+    if len(entries) != 512 or any(value < 0 or value > INT_MAX["u32"] for value in entries):
+        return None
+    literal_entries = [value for value in entries if (value & 255) == 0]
+    if not literal_entries:
+        return None
+    if any(not (1 <= ((value >> 8) & 255) <= 9) for value in literal_entries):
+        return None
+    if any((value >> 16) > 255 for value in literal_entries):
+        return None
+    # At most five prior 9-bit drops precede the sixth 9-bit lookup.  A byte
+    # cursor can start seven bits into the loaded word, so 7 + 6*9 = 61 <= 64.
+    if 7 + 6 * 9 > 64:
+        return None
+    return {
+        "shape_sha256": digest,
+        "table": consts[0]["name"],
+        "table_entries": len(entries),
+        "lookup_bits": 9,
+        "max_used": 9,
+        "batch": 6,
+        "window_bits": 64,
+        "src": f["params"][0]["name"],
+        "out": f["params"][1]["name"],
+        "count": f["params"][2]["name"],
+    }
+
