+    identifiers = {}
+    labels = {}
+    regions = {name: f"r{index}" for index, name in enumerate(f["regions"])}
+    for index, param in enumerate(f["params"]):
+        identifiers[param["name"]] = f"p{index}"
+    for index, const in enumerate(consts):
+        identifiers[const["name"]] = f"c{index}"
+    value_counter = [0]
+    label_counter = [0]
