+    def collect(value):
+        if isinstance(value, list):
+            for item in value:
+                collect(item)
+            return
+        if not isinstance(value, dict):
+            return
+        if value.get("s") in ("let", "try") and value.get("n") not in identifiers:
+            identifiers[value["n"]] = f"v{value_counter[0]}"
+            value_counter[0] += 1
+        if value.get("s") == "loop" and value.get("l") not in labels:
+            labels[value["l"]] = f"@l{label_counter[0]}"
+            label_counter[0] += 1
+        if value.get("s") == "match":
+            for arm in value.get("arms", []):
+                for binder in arm.get("b", []):
+                    if binder["name"] not in identifiers:
+                        identifiers[binder["name"]] = f"v{value_counter[0]}"
+                        value_counter[0] += 1
+        for child in value.values():
+            collect(child)
+
+    collect(f.get("requires") or [])
+    collect(f["body"])
+
+    def normalize(value):
+        if isinstance(value, list):
+            return [
+                normalize(item)
+                for item in value
+                if not (isinstance(item, dict) and item.get("s") == "doc")
+            ]
+        if isinstance(value, dict):
+            out = {}
+            for key in sorted(value):
+                if key == "msg" or (key == "s" and value.get("s") == "doc"):
+                    continue
+                child = value[key]
+                if key in ("name", "n", "base") and isinstance(child, str):
+                    child = identifiers.get(child, child)
+                elif key == "l" and isinstance(child, str):
+                    child = labels.get(child, child)
+                elif key == "region" and isinstance(child, str):
+                    child = regions.get(child, child)
